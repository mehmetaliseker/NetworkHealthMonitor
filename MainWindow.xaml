                                                <Button Content="Seçili alıcıyı sil" Command="{Binding RemoveInitialEmailRecipientCommand}" Style="{StaticResource DangerToolbarButtonStyle}" HorizontalAlignment="Right" Margin="0,8,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="Uzun süre çevrimdışı kalma alıcıları" FontWeight="SemiBold" Margin="0,0,0,8" />
                                                <DockPanel Margin="0,0,0,8">
                                                    <Button DockPanel.Dock="Right" Content="Ekle" Command="{Binding AddEscalationEmailRecipientCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" Margin="8,0,0,0" />
                                                    <TextBox Text="{Binding NewEscalationEmailAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" />
                                                </DockPanel>
                                                <DataGrid ItemsSource="{Binding EscalationEmailRecipients}" SelectedItem="{Binding SelectedEscalationEmailRecipient}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" MaxHeight="240">
                                                    <DataGrid.Columns>
                                                        <DataGridTextColumn Header="Görünen ad" Binding="{Binding DisplayName}" Width="*" />
                                                        <DataGridTextColumn Header="E-posta adresi" Binding="{Binding Email}" Width="1.5*" />
                                                    </DataGrid.Columns>
                                                </DataGrid>
                                                <Button Content="Seçili alıcıyı sil" Command="{Binding RemoveEscalationEmailRecipientCommand}" Style="{StaticResource DangerToolbarButtonStyle}" HorizontalAlignment="Right" Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Liste değişiklikleri kaydedildikten sonra izleme hizmeti bir sonraki ayar okumasında yeni alıcıları kullanır." Style="{StaticResource BodyMutedTextStyle}" Margin="0,12,0,0" />
                                        <WrapPanel HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <Button Content="Kaydet" Command="{Binding SaveSettingsCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsSettingsTemplatesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Style="{StaticResource PanelSectionStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Bildirim şablonları" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                        <TextBlock Text="{Binding AvailableEmailTemplatePlaceholdersText}" Style="{StaticResource BodyMutedTextStyle}" Margin="0,0,0,10" />
                                        <TextBlock Text="{Binding EmailTemplateValidationText}" Foreground="{StaticResource ShellWarningBrush}" TextWrapping="Wrap" Margin="0,0,0,10" />
                                        <TabControl>
                                            <TabItem Header="İlk çevrimdışı e-postası">
                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,10,0">
                                                        <TextBlock Text="Konu" Style="{StaticResource FormFieldLabelStyle}" />
                                                        <TextBox Text="{Binding InitialOfflineEmailSubjectTemplate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                                        <TextBlock Text="Gövde" Style="{StaticResource FormFieldLabelStyle}" />
                                                        <TextBox Text="{Binding InitialOfflineEmailBodyTemplate, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="220" Style="{StaticResource FormTextBoxStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Önizleme" Style="{StaticResource FormFieldLabelStyle}" />
                                                        <TextBox Text="{Binding InitialEmailPreviewText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="280" Style="{StaticResource FormTextBoxStyle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </TabItem>
                                            <TabItem Header="Escalation e-postası">
                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,10,0">
                                                        <TextBlock Text="Konu" Style="{StaticResource FormFieldLabelStyle}" />
                                                        <TextBox Text="{Binding EscalationEmailSubjectTemplate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                                        <TextBlock Text="Gövde" Style="{StaticResource FormFieldLabelStyle}" />
                                                        <TextBox Text="{Binding EscalationEmailBodyTemplate, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="220" Style="{StaticResource FormTextBoxStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Önizleme" Style="{StaticResource FormFieldLabelStyle}" />
                                                        <TextBox Text="{Binding EscalationEmailPreviewText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="280" Style="{StaticResource FormTextBoxStyle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </TabItem>
                                            <TabItem Header="Cihaz düzeldi e-postası">
                                                <Grid Margin="0,12,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Margin="0,0,10,0">
                                                        <TextBlock Text="Konu" Style="{StaticResource FormFieldLabelStyle}" />
                                                        <TextBox Text="{Binding RecoveredEmailSubjectTemplate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                                        <TextBlock Text="Gövde" Style="{StaticResource FormFieldLabelStyle}" />
                                                        <TextBox Text="{Binding RecoveredEmailBodyTemplate, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="220" Style="{StaticResource FormTextBoxStyle}" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1">
                                                        <TextBlock Text="Önizleme" Style="{StaticResource FormFieldLabelStyle}" />
                                                        <TextBox Text="{Binding InitialEmailPreviewText, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" MinHeight="280" Style="{StaticResource FormTextBoxStyle}" />
                                                    </StackPanel>
                                                </Grid>
                                            </TabItem>
                                        </TabControl>
                                        <WrapPanel HorizontalAlignment="Right" Margin="0,12,0,0">
                                            <CheckBox Content="HTML olarak gönder" IsChecked="{Binding EmailTemplatesAreHtml}" VerticalAlignment="Center" Margin="0,0,16,8" />
                                            <Button Content="Varsayılana döndür" Command="{Binding ResetEmailTemplatesCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                            <Button Content="Test gönderimi" Command="{Binding SendTestEmailCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                            <Button Content="Kaydet" Command="{Binding SaveSettingsCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsSettingsRetentionSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Style="{StaticResource PanelSectionStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Veri saklama" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                        <TextBlock Text="Log saklama süresi, gün" Style="{StaticResource FormFieldLabelStyle}" />
                                        <TextBox Text="{Binding LogRetentionDays}" Style="{StaticResource FormTextBoxStyle}" Width="160" HorizontalAlignment="Left" />
                                        <TextBlock Text="Varsayılan veritabanı konumu" Style="{StaticResource FormFieldLabelStyle}" />
                                        <TextBox Text="{Binding DatabaseLocation, Mode=OneWay}" IsReadOnly="True" Style="{StaticResource FormTextBoxStyle}" />
                                        <WrapPanel HorizontalAlignment="Right">
                                            <Button Content="Eski logları temizle" Command="{Binding ClearOldLogsCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                            <Button Content="Tüm logları temizle" Command="{Binding ClearLogsCommand}" Style="{StaticResource DangerToolbarButtonStyle}" />
                                            <Button Content="Yedek al" Command="{Binding BackupDatabaseCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                            <Button Content="Veritabanını iyileştir" Command="{Binding OptimizeDatabaseCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                            <Button Content="Kaydet" Command="{Binding SaveSettingsCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsSettingsAdvancedSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Style="{StaticResource PanelSectionStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Gelişmiş" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                        <TextBlock Text="Bakım pencereleri ve izleme takvimleri mevcut servis sözleşmeleriyle korunur. Bu ekranlar ayrı iş akışlarına yönlendirir." Style="{StaticResource BodyMutedTextStyle}" Margin="0,0,0,12" />
                                        <WrapPanel>
                                            <Button Content="Bakım pencereleri" Command="{Binding NavigateMaintenanceCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                            <Button Content="İzleme takvimleri" Command="{Binding NavigateCalendarsCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                            <Button Content="Ayarları dışa aktar" Command="{Binding ExportSettingsCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                            <Button Content="Ayarları içe aktar" Command="{Binding ImportSettingsCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                            <Button Content="Log klasörünü aç" Command="{Binding OpenLogFolderCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <StackPanel Visibility="{Binding IsSettingsReadinessSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Style="{StaticResource PanelSectionStyle}">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Content="Yenile" Command="{Binding RefreshReadinessCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                                        <StackPanel>
                                            <TextBlock Text="Sistem durumu" FontSize="18" FontWeight="SemiBold" />
                                            <TextBlock Text="İzleme hizmeti, bildirim kuyruğu ve veritabanı kontrolleri burada izlenir." Style="{StaticResource BodyMutedTextStyle}" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource PanelSectionStyle}" Margin="0,0,10,0">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Top" Text="Hazırlık kontrolleri" FontWeight="SemiBold" Margin="0,0,0,8" />
                                            <DataGrid ItemsSource="{Binding ServiceReadinessChecks}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" MaxHeight="320">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Durum" Binding="{Binding LevelText}" Width="95" />
                                                    <DataGridTextColumn Header="Kontrol" Binding="{Binding Name}" Width="1.4*" />
                                                    <DataGridTextColumn Header="Açıklama" Binding="{Binding Message}" Width="2*" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource PanelSectionStyle}">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Top" Text="Tanılama" FontWeight="SemiBold" Margin="0,0,0,8" />
                                            <DataGrid ItemsSource="{Binding ServiceDiagnostics}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" MaxHeight="320">
                                                <DataGrid.Columns>
                                                    <DataGridTextColumn Header="Durum" Binding="{Binding LevelText}" Width="95" />
                                                    <DataGridTextColumn Header="Kontrol" Binding="{Binding Name}" Width="1.4*" />
                                                    <DataGridTextColumn Header="Açıklama" Binding="{Binding Message}" Width="2*" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                                </DataGrid.Columns>
                                            </DataGrid>
                                        </DockPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>

                <Grid Visibility="{Binding IsMaintenanceSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="380" />
                    </Grid.ColumnDefinitions>
                    <DataGrid ItemsSource="{Binding MaintenanceWindows}" SelectedItem="{Binding SelectedMaintenanceWindow}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" Margin="0,0,14,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="1.3*" />
                            <DataGridTextColumn Header="Durum" Binding="{Binding StatusText}" Width="110" />
                            <DataGridTextColumn Header="Başlangıç" Binding="{Binding StartsAtText}" Width="150" />
                            <DataGridTextColumn Header="Bitiş" Binding="{Binding EndsAtText}" Width="150" />
                            <DataGridTextColumn Header="Kapsam" Binding="{Binding ScopeText}" Width="1.4*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Column="1" Style="{StaticResource PanelSurfaceStyle}">
                        <StackPanel>
                            <TextBlock Text="Bakım penceresi" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Bu iş akışı mevcut bakım servisi üzerinden çalışır." Style="{StaticResource BodyMutedTextStyle}" Margin="0,0,0,12" />
                            <WrapPanel>
                                <Button Content="İptal et" Command="{Binding CancelSelectedMaintenanceWindowCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                <Button Content="Tamamlandı işaretle" Command="{Binding CompleteSelectedMaintenanceWindowCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                                <Button Content="Ayarlar" Command="{Binding NavigateSettingsAdvancedCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding IsCalendarsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="380" />
                    </Grid.ColumnDefinitions>
                    <DataGrid ItemsSource="{Binding MonitoringCalendars}" SelectedItem="{Binding SelectedMonitoringCalendar}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" Margin="0,0,14,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="1.3*" />
                            <DataGridTextColumn Header="Saat dilimi" Binding="{Binding TimezoneId}" Width="170" />
                            <DataGridTextColumn Header="Durum" Binding="{Binding IsEnabledText}" Width="100" />
                            <DataGridTextColumn Header="Kural" Binding="{Binding RulesText}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Column="1" Style="{StaticResource PanelSurfaceStyle}">
                        <StackPanel>
                            <TextBlock Text="İzleme takvimleri" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Takvim kayıtları planlı kontrollerin ne zaman çalışacağını belirler." Style="{StaticResource BodyMutedTextStyle}" Margin="0,0,0,12" />
                            <WrapPanel>
                                <Button Content="Sil" Command="{Binding DeleteSelectedMonitoringCalendarCommand}" Style="{StaticResource DangerToolbarButtonStyle}" />
                                <Button Content="Ayarlar" Command="{Binding NavigateSettingsAdvancedCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Row="3" Style="{StaticResource PanelSurfaceStyle}" Padding="12,8" Margin="0,12,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource ShellMutedTextBrush}" TextWrapping="Wrap" />
                        <ProgressBar Height="8" Minimum="0" Maximum="100" Value="{Binding PingProgressPercent, Mode=OneWay}" Visibility="{Binding CanShowPingProgress, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,6,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="İptal" Command="{Binding CancelPingCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" Visibility="{Binding CanShowPingProgress, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>

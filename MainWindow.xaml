<Window x:Class="NetworkHealthMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:NetworkHealthMonitor.Converters"
        xmlns:infra="clr-namespace:NetworkHealthMonitor.Infrastructure"
        mc:Ignorable="d"
        Title="Ağ Cihazları Kontrol Paneli"
        Height="860"
        Width="1380"
        MinHeight="720"
        MinWidth="1024"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StatusBackgroundConverter x:Key="StatusBackgroundConverter" />
        <converters:StatusForegroundConverter x:Key="StatusForegroundConverter" />
        <converters:RowStatusBackgroundConverter x:Key="RowStatusBackgroundConverter" />
        <Style x:Key="TrimmedCellTextStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=Text}" />
        </Style>
        <Style x:Key="DetailLabelTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="DetailValueTextStyle" TargetType="TextBlock" BasedOn="{StaticResource TrimmedCellTextStyle}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="244" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Ağ Cihazları"
                               Foreground="White"
                               FontSize="21"
                               FontWeight="Bold" />
                    <TextBlock Text="Kontrol Paneli"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               Margin="0,3,0,22" />

                    <Button Content="Genel Bakış"
                            Command="{Binding NavigateDashboardCommand}"
                            Tag="{Binding IsDashboardNavSelected}"
                            ToolTip="Genel Bakış"
                            Style="{StaticResource SidebarNavButtonStyle}" />
                    <Button Content="Cihazlar"
                            Command="{Binding NavigateDevicesCommand}"
                            Tag="{Binding IsDevicesNavSelected}"
                            ToolTip="Cihazlar"
                            Style="{StaticResource SidebarNavButtonStyle}" />
                    <Button Content="Kontrol Planları"
                            Command="{Binding NavigateSchedulesCommand}"
                            Tag="{Binding IsSchedulesNavSelected}"
                            ToolTip="Kontrol Planları"
                            Style="{StaticResource SidebarNavButtonStyle}" />
                    <Button Content="Ping Kayıtları"
                            Command="{Binding NavigateLogsCommand}"
                            Tag="{Binding IsLogsNavSelected}"
                            ToolTip="Ping Kayıtları"
                            Style="{StaticResource SidebarNavButtonStyle}" />
                    <Button Content="Kesintiler"
                            Command="{Binding NavigateAvailabilityCommand}"
                            Tag="{Binding IsAvailabilityNavSelected}"
                            ToolTip="Kesintiler"
                            Style="{StaticResource SidebarNavButtonStyle}" />
                    <Button Content="Bildirimler"
                            Command="{Binding NavigateNotificationsCommand}"
                            Tag="{Binding IsNotificationsNavSelected}"
                            ToolTip="Bildirimler"
                            Style="{StaticResource SidebarNavButtonStyle}" />
                    <Button Content="Ayarlar"
                            Command="{Binding NavigateSettingsCommand}"
                            Tag="{Binding IsSettingsNavSelected}"
                            ToolTip="Ayarlar"
                            Style="{StaticResource SidebarNavButtonStyle}" />
                    <Button Content="Sistem Durumu"
                            Command="{Binding NavigateReadinessCommand}"
                            Tag="{Binding IsReadinessNavSelected}"
                            ToolTip="Sistem Durumu"
                            Style="{StaticResource SidebarNavButtonStyle}" />

                    <Separator Margin="0,14,0,10" Background="#374151" />
                    <TextBlock Text="Diğer"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Margin="4,0,0,6" />
                    <Button Content="Cihaz Grupları"
                            Command="{Binding NavigateGroupsCommand}"
                            Tag="{Binding IsGroupsNavSelected}"
                            ToolTip="Cihaz Grupları"
                            Style="{StaticResource SidebarSecondaryNavButtonStyle}" />
                    <Button Content="Bakım"
                            Command="{Binding NavigateMaintenanceCommand}"
                            Tag="{Binding IsMaintenanceNavSelected}"
                            ToolTip="Bakım"
                            Style="{StaticResource SidebarSecondaryNavButtonStyle}" />
                    <Button Content="İzleme Takvimleri"
                            Command="{Binding NavigateCalendarsCommand}"
                            Tag="{Binding IsCalendarsNavSelected}"
                            ToolTip="İzleme Takvimleri"
                            Style="{StaticResource SidebarSecondaryNavButtonStyle}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                    <TextBlock Text="İzleme servisi"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               FontSize="12" />
                    <TextBlock Text="{Binding SchedulerStatusText}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Margin="0,2,0,10" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding SectionTitle}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="{Binding SectionSubtitle}" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button Content="Tümüne Ping" Command="{Binding PingAllCommand}" />
                        <Button Content="Filtreye Ping" Command="{Binding PingFilteredDevicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="İptal" Command="{Binding CancelPingCommand}" Style="{StaticResource DangerButtonStyle}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ItemsControl Grid.Row="0" ItemsSource="{Binding SummaryCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{Binding AccentColor}" CornerRadius="4" />
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Value}" FontSize="21" FontWeight="Bold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="1"
                        Style="{StaticResource SectionBorderStyle}"
                        Visibility="{Binding CanShowPingProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Height="10" Minimum="0" Maximum="100" Value="{Binding PingProgressPercent, Mode=OneWay}" />
                        <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Margin="12,0,0,0" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid Visibility="{Binding IsDashboardSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,12,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Son Başarısız Cihazlar" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <DataGrid ItemsSource="{Binding RecentFailureLogs}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Saat" Binding="{Binding CheckedAtText}" Width="135" />
                                    <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="*" />
                                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SectionBorderStyle}" Margin="0,0,12,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Kritik Cihaz Durumu" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <DataGrid ItemsSource="{Binding CriticalProblemDevices}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Cihaz" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                                    <DataGridTextColumn Header="Hata" Binding="{Binding ConsecutiveFailuresText}" Width="70" />
                                    <DataGridTextColumn Header="Son kontrol" Binding="{Binding LastCheckedAtText}" Width="145" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,12,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Son Ping Logları" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <DataGrid ItemsSource="{Binding RecentDashboardLogs}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Saat" Binding="{Binding CheckedAtText}" Width="135" />
                                    <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="*" />
                                    <DataGridTextColumn Header="Durum" Binding="{Binding StatusText}" Width="120" />
                                    <DataGridTextColumn Header="Kaynak" Binding="{Binding TriggerTypeText}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SectionBorderStyle}" Margin="0,0,12,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="En Düşük Erişilebilirlik" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <DataGrid ItemsSource="{Binding LowAvailabilityDevices}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="*" />
                                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                                    <DataGridTextColumn Header="30 gün" Binding="{Binding Availability30DaysText}" Width="90" />
                                    <DataGridTextColumn Header="Kesinti" Binding="{Binding OutageCount}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.RowSpan="2" Grid.Column="2" Style="{StaticResource SectionBorderStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Açık kesintiler" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <DataGrid ItemsSource="{Binding OpenOutages}" Height="190" Margin="0,0,0,14">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="*" />
                                        <DataGridTextColumn Header="Süre" Binding="{Binding DurationText}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="Cihaz Tipi Dağılımı" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding DeviceTypeDistribution}" Margin="0,0,0,16">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="Bold" />
                                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="8" Maximum="100" Value="{Binding Percent}" Margin="0,4,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Grup Bazlı Erişilebilirlik" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding GroupAvailabilityRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="Bold" />
                                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="8" Maximum="100" Value="{Binding Percent}" Margin="0,4,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Son 30 Gün Erişilebilirlik Trendi" FontSize="16" FontWeight="Bold" Margin="0,16,0,8" />
                                <DataGrid ItemsSource="{Binding DashboardAvailabilityTrend}" Height="210" Margin="0,0,0,14">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Gün" Binding="{Binding DateText}" Width="70" />
                                        <DataGridTextColumn Header="Erişilebilirlik" Binding="{Binding AvailabilityText}" Width="105" />
                                        <DataGridTextColumn Header="Kapsam" Binding="{Binding CoverageText}" Width="95" />
                                        <DataGridTextColumn Header="Belirsiz" Binding="{Binding UnknownText}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="En Uzun 10 Kesinti" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <DataGrid ItemsSource="{Binding LongestOutages}" Height="210" Margin="0,0,0,14">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cihaz" Binding="{Binding Title}" Width="*" />
                                        <DataGridTextColumn Header="IP / Grup" Binding="{Binding Subtitle}" Width="130" />
                                        <DataGridTextColumn Header="Süre" Binding="{Binding Value}" Width="95" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="En Çok Kesinti Yaşayan 10 Cihaz" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <DataGrid ItemsSource="{Binding IncidentRanking}" Height="210" Margin="0,0,0,14">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cihaz" Binding="{Binding Title}" Width="*" />
                                        <DataGridTextColumn Header="IP / Grup" Binding="{Binding Subtitle}" Width="130" />
                                        <DataGridTextColumn Header="Kesinti" Binding="{Binding Value}" Width="80" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="Belirsiz Süresi En Yüksek Cihazlar" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <DataGrid ItemsSource="{Binding UnknownDurationRanking}" Height="210" Margin="0,0,0,14">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cihaz" Binding="{Binding Title}" Width="*" />
                                        <DataGridTextColumn Header="IP" Binding="{Binding Subtitle}" Width="130" />
                                        <DataGridTextColumn Header="Belirsiz" Binding="{Binding Value}" Width="95" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="Veri Kapsamı Düşük Cihazlar" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <DataGrid ItemsSource="{Binding LowCoverageRanking}" Height="210">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cihaz" Binding="{Binding Title}" Width="*" />
                                        <DataGridTextColumn Header="IP" Binding="{Binding Subtitle}" Width="130" />
                                        <DataGridTextColumn Header="Kapsam" Binding="{Binding Value}" Width="95" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding IsDevicesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                        <StackPanel>
                            <WrapPanel VerticalAlignment="Center">
                                <TextBox Width="260" Text="{Binding DeviceSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Cihaz adı, IP, lokasyon, grup veya açıklama ara" />
                                <ComboBox Width="150" ItemsSource="{Binding DeviceTypeFilterOptions}" SelectedItem="{Binding DeviceTypeFilter}" Margin="8,0,0,0" />
                                <ComboBox Width="160" ItemsSource="{Binding DeviceStatusFilterOptions}" SelectedItem="{Binding DeviceStatusFilter}" Margin="8,0,0,0" />
                                <ComboBox Width="170" ItemsSource="{Binding DeviceGroupFilterOptions}" SelectedItem="{Binding DeviceGroupFilter}" Margin="8,0,0,0" />
                                <ComboBox Width="150" ItemsSource="{Binding CriticalFilterOptions}" SelectedItem="{Binding CriticalFilter}" Margin="8,0,0,0" />
                                <ComboBox Width="150" ItemsSource="{Binding DeviceDeletedFilterOptions}" SelectedItem="{Binding DeletedDeviceFilter}" Margin="8,0,0,0" />
                                <Button Content="Tipe Ping" Command="{Binding PingSelectedTypeCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                            <WrapPanel VerticalAlignment="Center" Margin="0,10,0,0">
                                <Button Content="Yeni cihaz ekle" Command="{Binding NavigateDeviceEditCommand}" />
                                <Button Content="CSV'den içe aktar" Command="{Binding ImportDevicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="CSV'ye aktar" Command="{Binding ExportDevicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Listeyi yenile" Command="{Binding RefreshDevicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Filtreleri temizle" Command="{Binding ClearDeviceFiltersCommand}" Style="{StaticResource GhostButtonStyle}" />
                                <TextBlock Text="{Binding ActiveDeviceFilterCountText}"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontWeight="SemiBold"
                                           Margin="10,0,0,0" />
                            </WrapPanel>
                            <WrapPanel VerticalAlignment="Center" Margin="0,8,0,0">
                                <TextBlock Text="CSV modu:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,8,0" />
                                <ComboBox Width="210" ItemsSource="{Binding CsvImportModeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding CsvImportMode}" />
                                <ComboBox Width="230" ItemsSource="{Binding CsvImportScopeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding CsvImportScope}" Margin="8,0,0,0" />
                                <ComboBox Width="170" ItemsSource="{Binding DeviceGroupOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding CsvImportGroupId}" Margin="8,0,0,0" ToolTip="Grup kapsamlı eşitleme için seçili grup" />
                                <Button Content="CSV önizle" Command="{Binding ImportDevicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="İçe aktar" Command="{Binding ApplyCsvImportCommand}" />
                                <Button Content="CSV şablonu" Command="{Binding CreateCsvTemplateCommand}" Style="{StaticResource GhostButtonStyle}" />
                            </WrapPanel>
                            <WrapPanel VerticalAlignment="Center" Margin="0,8,0,0">
                                <TextBlock Text="Toplu işlem:" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,8,0" />
                                <TextBlock Text="{Binding SelectedDeviceCountText}" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,8,0" />
                                <Button Content="Seçilileri Ping" Command="{Binding PingSelectedDevicesBulkCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Oto Aç" Command="{Binding EnableAutoCheckSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Oto Kapat" Command="{Binding DisableAutoCheckSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SecondaryButtonStyle}" />
                                <ComboBox Width="150" ItemsSource="{Binding DeviceGroupOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding BulkTargetGroupId}" Margin="8,0,0,0" ToolTip="Seçili cihazları atanacak grup" />
                                <Button Content="Gruba Ata" Command="{Binding AssignSelectedDevicesToGroupCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SecondaryButtonStyle}" />
                                <TextBox Width="72" Text="{Binding BulkCheckIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" ToolTip="Toplu özel kontrol aralığı saniye. 0 = politika devral." Margin="8,0,0,0" />
                                <Button Content="Aralık Uygula" Command="{Binding ApplySelectedCheckIntervalCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Pasifleştir" Command="{Binding DeactivateSelectedDevicesCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource DangerButtonStyle}" />
                                <Button Content="Seçilenleri Sil" Command="{Binding DeleteSelectedDevicesBulkCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource DangerButtonStyle}" />
                                <Button Content="Seçilenleri geri yükle" Command="{Binding RestoreSelectedDevicesBulkCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                            <TextBlock Text="{Binding CsvImportPreviewSummary}" Margin="0,8,0,0" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition>
                                <ColumnDefinition.Style>
                                    <Style TargetType="ColumnDefinition">
                                        <Setter Property="Width" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowDeviceFormPane}" Value="True">
                                                <Setter Property="Width" Value="380" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ColumnDefinition.Style>
                            </ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0"
                              Visibility="{Binding ShowDeviceListPane, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <DataGrid x:Name="DevicesGrid"
                              ItemsSource="{Binding DevicesView}"
                              SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                              SelectionMode="Extended"
                              SelectionUnit="FullRow"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.InputBindings>
                            <KeyBinding Key="Delete" Command="{Binding DeleteSelectedDeviceCommand}" />
                        </DataGrid.InputBindings>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Seçilen cihazları sil" Command="{Binding PlacementTarget.DataContext.DeleteSelectedDevicesBulkCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Seçilen cihazları geri yükle" Command="{Binding PlacementTarget.DataContext.RestoreSelectedDevicesBulkCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" CommandParameter="{Binding PlacementTarget.SelectedItems, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                <MenuItem Header="Cihazı sil" Command="{Binding DeleteSelectedDeviceCommand}" />
                                <MenuItem Header="Geri yükle" Command="{Binding RestoreSelectedDeviceCommand}" />
                                <MenuItem Header="Ping" Command="{Binding PingSelectedDeviceCommand}" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding LastStatus, Converter={StaticResource RowStatusBackgroundConverter}}" />
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Width="42">
                                <DataGridTemplateColumn.Header>
                                    <CheckBox IsChecked="{Binding DataContext.SelectAllVisibleDevices, RelativeSource={RelativeSource AncestorType=DataGrid}, Mode=TwoWay}" ToolTip="Tüm görünenleri seç" />
                                </DataGridTemplateColumn.Header>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Durum" Width="165">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding LastStatus, Converter={StaticResource StatusBackgroundConverter}}"
                                                CornerRadius="6"
                                                Padding="8,4"
                                                HorizontalAlignment="Left"
                                                ToolTip="{Binding HealthHintText}">
                                            <TextBlock Text="{Binding LastStatusText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{Binding LastStatus, Converter={StaticResource StatusForegroundConverter}}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="1.5*" ElementStyle="{StaticResource TrimmedCellTextStyle}" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="125" SortMemberPath="IpSortKey" ElementStyle="{StaticResource TrimmedCellTextStyle}" />
                            <DataGridTextColumn Header="Tip" Binding="{Binding DeviceTypeText}" Width="110" ElementStyle="{StaticResource TrimmedCellTextStyle}" />
                            <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="1*" ElementStyle="{StaticResource TrimmedCellTextStyle}" />
                            <DataGridTextColumn Header="Kayıt" Binding="{Binding IsDeletedOrDisabledText}" Width="90" ElementStyle="{StaticResource TrimmedCellTextStyle}" />
                            <DataGridTextColumn Header="Son kontrol" Binding="{Binding LastCheckedAtText}" Width="145" ElementStyle="{StaticResource TrimmedCellTextStyle}" />
                            <DataGridTextColumn Header="Gecikme" Binding="{Binding LastLatencyText}" Width="85" ElementStyle="{StaticResource TrimmedCellTextStyle}" />
                            <DataGridTextColumn Header="Aktif plan" Binding="{Binding EffectivePolicyText}" Width="130" ElementStyle="{StaticResource TrimmedCellTextStyle}" />
                            <DataGridTemplateColumn Header="İşlem" Width="215">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Ping"
                                                    Style="{StaticResource SmallButtonStyle}"
                                                    Command="{Binding DataContext.PingDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Düzenle"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                                    Command="{Binding DataContext.EditDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Sil"
                                                    Style="{StaticResource SmallDangerButtonStyle}"
                                                    Command="{Binding DataContext.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Geri"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                                    Command="{Binding DataContext.RestoreDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                                <Border Background="#F8FAFC"
                                        BorderBrush="{StaticResource PanelBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Visibility="{Binding HasNoFilteredDevices, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="24">
                                        <TextBlock Text="Filtreye uyan cihaz bulunamadı"
                                                   Style="{StaticResource EmptyStateStyle}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Margin="0" />
                                        <TextBlock Text="Filtreleri temizleyerek veya arama metnini değiştirerek tekrar deneyin."
                                                   Style="{StaticResource EmptyStateStyle}"
                                                   Margin="0,8,0,12" />
                                        <Button Content="Filtreleri temizle"
                                                Command="{Binding ClearDeviceFiltersCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                HorizontalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                    <Border Grid.Row="1" Style="{StaticResource SectionBorderStyle}" Margin="0,12,0,0">
                        <TabControl Height="210">
                            <TabItem Header="Yeni / Geri yüklenecek">
                                <DataGrid ItemsSource="{Binding CsvNewRows}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Satır" Binding="{Binding RowNumber}" Width="60" />
                                        <DataGridTextColumn Header="Durum" Binding="{Binding StatusText}" Width="120" />
                                        <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="130" />
                                        <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="140" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Güncellenecek">
                                <DataGrid ItemsSource="{Binding CsvUpdateRows}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Satır" Binding="{Binding RowNumber}" Width="60" />
                                        <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="130" />
                                        <DataGridTextColumn Header="Değişiklik" Binding="{Binding ChangeSummary}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Silinecek">
                                <DataGrid ItemsSource="{Binding CsvDeleteRows}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="130" />
                                        <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="140" />
                                        <DataGridTextColumn Header="Neden" Binding="{Binding ChangeSummary}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Hatalı satırlar">
                                <DataGrid ItemsSource="{Binding CsvInvalidRows}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Satır" Binding="{Binding RowNumber}" Width="60" />
                                        <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="130" />
                                        <DataGridTextColumn Header="Hata" Binding="{Binding ErrorMessage}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Yinelenen kayıt">
                                <DataGrid ItemsSource="{Binding CsvDuplicateRows}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Satır" Binding="{Binding RowNumber}" Width="60" />
                                        <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="130" />
                                        <DataGridTextColumn Header="Hata" Binding="{Binding ErrorMessage}" Width="2*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                            <TabItem Header="Değişmeyen / Atlanan">
                                <DataGrid ItemsSource="{Binding CsvUnchangedRows}" AutoGenerateColumns="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Satır" Binding="{Binding RowNumber}" Width="60" />
                                        <DataGridTextColumn Header="Durum" Binding="{Binding StatusText}" Width="120" />
                                        <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="*" />
                                        <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="130" />
                                    </DataGrid.Columns>
                                </DataGrid>
                            </TabItem>
                        </TabControl>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource SectionBorderStyle}" Margin="0,12,0,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                                <TextBlock Text="Cihaz Detayı" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" />
                                <Border Background="{Binding SelectedDevice.LastStatus, Converter={StaticResource StatusBackgroundConverter}}"
                                        CornerRadius="6"
                                        Padding="8,4"
                                        Margin="14,0,0,0"
                                        ToolTip="{Binding SelectedDevice.HealthHintText}">
                                    <TextBlock Text="{Binding SelectedDevice.LastStatusText, TargetNullValue='Seçili cihaz yok'}"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding SelectedDevice.LastStatus, Converter={StaticResource StatusForegroundConverter}}"
                                               FontWeight="SemiBold" />
                                </Border>
                                <Button Content="Ping" Command="{Binding PingSelectedDeviceCommand}" Style="{StaticResource SmallButtonStyle}" Margin="12,0,0,0" />
                                <Button Content="Düzenle" Command="{Binding EditSelectedDeviceCommand}" Style="{StaticResource SmallSecondaryButtonStyle}" Margin="4,0,0,0" />
                                <Button Content="Sil" Command="{Binding DeleteSelectedDeviceCommand}" Style="{StaticResource SmallDangerButtonStyle}" Margin="4,0,0,0" />
                                <Button Content="Geri Yükle" Command="{Binding RestoreSelectedDeviceCommand}" Style="{StaticResource SmallSecondaryButtonStyle}" Margin="4,0,0,0" />
                            </StackPanel>

                            <WrapPanel>
                                <StackPanel Width="210" Margin="0,0,18,8">
                                    <TextBlock Text="Ad / IP" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.Name, TargetNullValue='-'}" Style="{StaticResource DetailValueTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.IpAddress, TargetNullValue='-'}" Style="{StaticResource TrimmedCellTextStyle}" />
                                </StackPanel>
                                <StackPanel Width="180" Margin="0,0,18,8">
                                    <TextBlock Text="Tip / Grup" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.DeviceTypeText, TargetNullValue='-'}" Style="{StaticResource DetailValueTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.GroupName, TargetNullValue='-'}" Style="{StaticResource TrimmedCellTextStyle}" />
                                </StackPanel>
                                <StackPanel Width="190" Margin="0,0,18,8">
                                    <TextBlock Text="Son kontrol" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.LastCheckedAtText, TargetNullValue='-'}" Style="{StaticResource DetailValueTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.LastLatencyText, TargetNullValue='-'}" Style="{StaticResource TrimmedCellTextStyle}" />
                                </StackPanel>
                                <StackPanel Width="230" Margin="0,0,18,8">
                                    <TextBlock Text="Son başarılı / başarısız" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.LastSuccessfulCheckAtText, TargetNullValue='-'}" Style="{StaticResource DetailValueTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.LastFailedCheckAtText, TargetNullValue='-'}" Style="{StaticResource TrimmedCellTextStyle}" />
                                </StackPanel>
                                <StackPanel Width="240" Margin="0,0,18,8">
                                    <TextBlock Text="Ağ erişilebilirliği" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Style="{StaticResource DetailValueTextStyle}">
                                        <Run Text="24s " />
                                        <Run Text="{Binding SelectedDevice.Uptime24HoursText, TargetNullValue='-'}" />
                                        <Run Text="  7g " />
                                        <Run Text="{Binding SelectedDevice.Uptime7DaysText, TargetNullValue='-'}" />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource TrimmedCellTextStyle}">
                                        <Run Text="30g " />
                                        <Run Text="{Binding SelectedDevice.Uptime30DaysText, TargetNullValue='-'}" />
                                        <Run Text="  Genel " />
                                        <Run Text="{Binding SelectedDevice.UptimeOverallText, TargetNullValue='-'}" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Width="220" Margin="0,0,18,8">
                                    <TextBlock Text="Otomatik kontrol" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.AutoCheckText, TargetNullValue='-'}" Style="{StaticResource DetailValueTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.IsActiveText, TargetNullValue='-'}" Style="{StaticResource TrimmedCellTextStyle}" />
                                </StackPanel>
                                <StackPanel Width="320" Margin="0,0,18,8">
                                    <TextBlock Text="Etkin politika" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.EffectivePolicyText, TargetNullValue='-'}"
                                               Style="{StaticResource DetailValueTextStyle}"
                                               TextWrapping="Wrap"
                                               ToolTip="{Binding SelectedDevice.EffectivePolicyText}" />
                                </StackPanel>
                                <StackPanel Width="280" Margin="0,0,18,8">
                                    <TextBlock Text="Politika değerleri" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Style="{StaticResource DetailValueTextStyle}">
                                        <Run Text="Normal " />
                                        <Run Text="{Binding SelectedDevice.CheckIntervalText, TargetNullValue='-'}" />
                                        <Run Text=" / Zaman aşımı " />
                                        <Run Text="{Binding SelectedDevice.PingTimeoutText, TargetNullValue='-'}" />
                                    </TextBlock>
                                    <TextBlock Style="{StaticResource TrimmedCellTextStyle}">
                                        <Run Text="Yeniden deneme " />
                                        <Run Text="{Binding SelectedDevice.FailureRetryIntervalText, TargetNullValue='-'}" />
                                        <Run Text=", limit " />
                                        <Run Text="{Binding SelectedDevice.FailureRetryLimitText, TargetNullValue='-'}" />
                                        <Run Text=", eşik " />
                                        <Run Text="{Binding SelectedDevice.FailureThresholdText, TargetNullValue='-'}" />
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel Width="170" Margin="0,0,18,8">
                                    <TextBlock Text="Hata takibi" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.ConsecutiveFailuresText, TargetNullValue='-'}" Style="{StaticResource DetailValueTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.LastFailureAtText, TargetNullValue='-'}" Style="{StaticResource TrimmedCellTextStyle}" />
                                </StackPanel>
                                <StackPanel Width="220" Margin="0,0,18,8">
                                    <TextBlock Text="Lokasyon" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.Location, TargetNullValue='-'}" Style="{StaticResource DetailValueTextStyle}" />
                                </StackPanel>
                                <StackPanel Width="360" Margin="0,0,18,8">
                                    <TextBlock Text="Açıklama" Style="{StaticResource DetailLabelTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.Description, TargetNullValue='-'}" Style="{StaticResource DetailValueTextStyle}" />
                                    <TextBlock Text="{Binding SelectedDevice.HealthHintText, TargetNullValue='-'}" Style="{StaticResource TrimmedCellTextStyle}" />
                                </StackPanel>
                            </WrapPanel>
                            <TabControl Height="250" Margin="0,12,0,0">
                                <TabItem Header="Erişilebilirlik ayrıntısı">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <WrapPanel Margin="8">
                                            <StackPanel Width="210" Margin="0,0,18,8">
                                                <TextBlock Text="Mevcut durum" Style="{StaticResource DetailLabelTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.CurrentStatus}" Style="{StaticResource DetailValueTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.CurrentStatusSince}" Style="{StaticResource TrimmedCellTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Width="230" Margin="0,0,18,8">
                                                <TextBlock Text="Kesintisiz erişilebilir süre" Style="{StaticResource DetailLabelTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.CurrentContinuousAvailability}" Style="{StaticResource DetailValueTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.OngoingDowntime}" Style="{StaticResource TrimmedCellTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Width="230" Margin="0,0,18,8">
                                                <TextBlock Text="İlk hata / Kesinti doğrulama" Style="{StaticResource DetailLabelTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.FirstFailureAt}" Style="{StaticResource DetailValueTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.ConfirmedDownAt}" Style="{StaticResource TrimmedCellTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Width="230" Margin="0,0,18,8">
                                                <TextBlock Text="Son başarılı / Son kontrol" Style="{StaticResource DetailLabelTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.LastSuccessfulCheck}" Style="{StaticResource DetailValueTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.LastCheck}" Style="{StaticResource TrimmedCellTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Width="230" Margin="0,0,18,8">
                                                <TextBlock Text="24s / 7g / 30g" Style="{StaticResource DetailLabelTextStyle}" />
                                                <TextBlock Style="{StaticResource DetailValueTextStyle}">
                                                    <Run Text="{Binding SelectedDeviceAvailabilityDetail.Availability24Hours}" />
                                                    <Run Text=" / " />
                                                    <Run Text="{Binding SelectedDeviceAvailabilityDetail.Availability7Days}" />
                                                </TextBlock>
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.Availability30Days}" Style="{StaticResource TrimmedCellTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Width="210" Margin="0,0,18,8">
                                                <TextBlock Text="Kapsam / Kesinti" Style="{StaticResource DetailLabelTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.Coverage}" Style="{StaticResource DetailValueTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.IncidentCount}" Style="{StaticResource TrimmedCellTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Width="210" Margin="0,0,18,8">
                                                <TextBlock Text="MTTR / MTBF" Style="{StaticResource DetailLabelTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.Mttr}" Style="{StaticResource DetailValueTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.Mtbf}" Style="{StaticResource TrimmedCellTextStyle}" />
                                            </StackPanel>
                                            <StackPanel Width="210" Margin="0,0,18,8">
                                                <TextBlock Text="SLA" Style="{StaticResource DetailLabelTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.SlaTarget}" Style="{StaticResource DetailValueTextStyle}" />
                                                <TextBlock Text="{Binding SelectedDeviceAvailabilityDetail.SlaStatus}" Style="{StaticResource TrimmedCellTextStyle}" />
                                            </StackPanel>
                                        </WrapPanel>
                                    </ScrollViewer>
                                </TabItem>
                                <TabItem Header="Dönem zaman çizelgesi">
                                    <DockPanel Margin="8">
                                        <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                            <ComboBox Width="150" ItemsSource="{Binding TimelineRangeOptions}" SelectedItem="{Binding SelectedTimelineRange}" />
                                            <DatePicker Width="130" SelectedDate="{Binding CustomTimelineStartDate}" Margin="8,0,0,0" />
                                            <DatePicker Width="130" SelectedDate="{Binding CustomTimelineEndDate}" Margin="8,0,0,0" />
                                            <Button Content="Yenile" Command="{Binding RefreshSelectedDeviceTimelineCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                        </WrapPanel>
                                        <DataGrid ItemsSource="{Binding SelectedDeviceAvailabilityTimeline}">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Durum" Binding="{Binding StatusText}" Width="130" />
                                                <DataGridTextColumn Header="Başlangıç" Binding="{Binding StartedAtText}" Width="150" />
                                                <DataGridTextColumn Header="Bitiş" Binding="{Binding EndedAtText}" Width="150" />
                                                <DataGridTextColumn Header="Neden" Binding="{Binding ReasonText}" Width="2*" />
                                                <DataGridTextColumn Header="Kaynak" Binding="{Binding DetectionSource}" Width="120" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </DockPanel>
                                </TabItem>
                            </TabControl>
                        </DockPanel>
                    </Border>
                        </Grid>

                        <ScrollViewer Grid.Column="1"
                                      VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding ShowDeviceFormPane, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ScrollViewer.Style>
                                <Style TargetType="ScrollViewer">
                                    <Setter Property="Grid.Column" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ShowDeviceListPane}" Value="False">
                                            <Setter Property="Grid.Column" Value="0" />
                                            <Setter Property="Grid.ColumnSpan" Value="2" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ScrollViewer.Style>
                    <Border Style="{StaticResource SectionBorderStyle}">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,14">
                                <Button DockPanel.Dock="Right"
                                        Content="Cihaz listesine dön"
                                        Command="{Binding CloseDeviceFormCommand}"
                                        Style="{StaticResource GhostButtonStyle}" />
                                <TextBlock Text="{Binding DeviceFormTitle}" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" />
                            </DockPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,12">
                                    <TextBlock Text="Cihaz adı" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,12">
                                    <TextBlock Text="IP adresi" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding FormIpAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,12">
                                    <TextBlock Text="Cihaz tipi" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding DeviceTypeOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding FormDeviceType}"
                                              Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,12">
                                    <TextBlock Text="Grup seçimi" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding DeviceGroupOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding FormGroupId}"
                                              Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,12">
                                    <TextBlock Text="Açıklama / lokasyon" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding FormLocation, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,12">
                                    <TextBlock Text="Varsayılan kontrol planı"
                                               FontWeight="SemiBold"
                                               ToolTip="Seçilen plan zamanı geldiğinde bu cihaz da otomatik hedef listesine eklenir." />
                                    <ComboBox ItemsSource="{Binding SchedulePlanOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding FormDefaultSchedulePlanId}"
                                              ToolTip="Seçilen plan zamanı geldiğinde bu cihaz da otomatik hedef listesine eklenir."
                                              Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,10,12">
                                    <TextBlock Text="Özel kontrol aralığı (sn)"
                                               FontWeight="SemiBold"
                                               ToolTip="0 yazılırsa cihaz grup, tip, plan veya global varsayılan aralığı kullanır." />
                                    <TextBox Text="{Binding FormCheckIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="0 = grup/tip/plan/global varsayılanı"
                                             Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="3" Grid.Column="1" Margin="10,0,0,12">
                                    <TextBlock Text="Özel ping zaman aşımı (ms)" FontWeight="SemiBold" ToolTip="Boş = grup/tip/global zaman aşımı." />
                                    <TextBox Text="{Binding FormPingTimeoutMs, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}"
                                             ToolTip="Boş = grup/tip/global zaman aşımı"
                                             Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,10,12">
                                    <TextBlock Text="Hızlı yeniden deneme aralığı (sn)" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding FormFailureRetryIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="4" Grid.Column="1" Margin="10,0,0,12">
                                    <TextBlock Text="Maksimum hızlı yeniden deneme" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding FormFailureRetryLimit, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,10,12">
                                    <TextBlock Text="Başarısızlık eşiği" FontWeight="SemiBold" ToolTip="0 = grup/tip/global eşik." />
                                    <TextBox Text="{Binding FormFailureThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Row="5"
                                           Grid.Column="1"
                                           Text="Başarısız ping önce kısa aralıkla tekrar denenir; tek hata kesin arıza sayılmaz, eşik ve retry limiti dolunca muhtemel erişilemiyor olarak izlenir."
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="10,2,0,12" />
                                <TextBox Grid.Row="6"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="90"
                                         VerticalContentAlignment="Top"
                                         Margin="0,4,0,12"
                                         ToolTip="Açıklama" />

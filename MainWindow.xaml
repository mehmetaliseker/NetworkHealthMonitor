<Window x:Class="NetworkHealthMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:NetworkHealthMonitor.Converters"
        xmlns:infra="clr-namespace:NetworkHealthMonitor.Infrastructure"
        mc:Ignorable="d"
        Title="Ağ İzleme Yönetim Paneli"
        Height="860"
        Width="1440"
        MinHeight="720"
        MinWidth="1120"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DesignSystem.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <converters:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <converters:BooleanToGridLengthConverter x:Key="NavigationWidthConverter" TrueWidth="76" FalseWidth="276" />
            <converters:StatusBackgroundConverter x:Key="StatusBackgroundConverter" />
            <converters:StatusForegroundConverter x:Key="StatusForegroundConverter" />
            <converters:RowStatusBackgroundConverter x:Key="RowStatusBackgroundConverter" />

            <Style x:Key="NavigationLabelStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="12,0,0,0" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="TextWrapping" Value="NoWrap" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsNavigationCollapsed}" Value="True">
                        <Setter Property="Visibility" Value="Collapsed" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>

            <Style x:Key="NavIconStyle" TargetType="TextBlock">
                <Setter Property="Width" Value="24" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="HorizontalAlignment" Value="Center" />
                <Setter Property="TextAlignment" Value="Center" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>

            <Style x:Key="FormFieldLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource MicroLabelTextStyle}">
                <Setter Property="Margin" Value="0,0,0,4" />
            </Style>

            <Style x:Key="FormTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource ModernTextBoxStyle}">
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>

            <Style x:Key="FormComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource ModernComboBoxStyle}">
                <Setter Property="Margin" Value="0,0,0,10" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Background="{StaticResource ShellBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{Binding IsNavigationCollapsed, Converter={StaticResource NavigationWidthConverter}}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource ShellNavigationBrush}">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top" Margin="10,12,10,8">
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="8" Background="#2563EB">
                                <TextBlock Text="N" Foreground="White" FontWeight="Bold" FontSize="17"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Margin="10,0,0,0" Visibility="{Binding IsNavigationCollapsed, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                <TextBlock Text="NetworkHealthMonitor" Foreground="White" FontWeight="SemiBold" FontSize="14" />
                                <TextBlock Text="Ağ izleme yönetimi" Foreground="#A7B2C4" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Width="34"
                                Height="34"
                                MinHeight="34"
                                Padding="0"
                                Margin="4,0,0,0"
                                Command="{Binding ToggleNavigationCommand}"
                                Style="{StaticResource NavigationButtonStyle}"
                                ToolTip="{Binding NavigationToggleText}">
                            <TextBlock Text="☰" FontSize="16" HorizontalAlignment="Center" />
                        </Button>
                    </Grid>

                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateDashboardCommand}"
                            Tag="{Binding IsDashboardNavSelected}"
                            ToolTip="Genel Bakış">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▦" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Text="Genel Bakış" Style="{StaticResource NavigationLabelStyle}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateDevicesCommand}"
                            Tag="{Binding IsDevicesNavSelected}"
                            ToolTip="Cihazlar">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▣" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Text="Cihazlar" Style="{StaticResource NavigationLabelStyle}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateGroupsCommand}"
                            Tag="{Binding IsGroupsNavSelected}"
                            ToolTip="Gruplar">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◎" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Text="Gruplar" Style="{StaticResource NavigationLabelStyle}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateSchedulesCommand}"
                            Tag="{Binding IsSchedulesNavSelected}"
                            ToolTip="İzleme Planları">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◷" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Text="İzleme Planları" Style="{StaticResource NavigationLabelStyle}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateEventsCommand}"
                            Tag="{Binding IsEventsNavSelected}"
                            ToolTip="Olaylar">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="!" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Text="Olaylar" Style="{StaticResource NavigationLabelStyle}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateNotificationsCommand}"
                            Tag="{Binding IsNotificationsNavSelected}"
                            ToolTip="Bildirimler">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↗" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Text="Bildirimler" Style="{StaticResource NavigationLabelStyle}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateLogsCommand}"
                            Tag="{Binding IsLogsNavSelected}"
                            ToolTip="Ping Logları">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="≡" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Text="Ping Logları" Style="{StaticResource NavigationLabelStyle}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateReportsCommand}"
                            Tag="{Binding IsReportsNavSelected}"
                            ToolTip="Raporlar / Uptime">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="%" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Text="Raporlar / Uptime" Style="{StaticResource NavigationLabelStyle}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavigationButtonStyle}"
                            Command="{Binding NavigateSettingsCommand}"
                            Tag="{Binding IsSettingsNavSelected}"
                            ToolTip="Ayarlar">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" Style="{StaticResource NavIconStyle}" />
                            <TextBlock Text="Ayarlar" Style="{StaticResource NavigationLabelStyle}" />
                        </StackPanel>
                    </Button>

                    <StackPanel Visibility="{Binding IsNavigationCollapsed, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                        <Button Content="Genel" Style="{StaticResource NavigationSubButtonStyle}" Command="{Binding NavigateSettingsGeneralCommand}" />
                        <Button Content="Ping ve Yeniden Deneme" Style="{StaticResource NavigationSubButtonStyle}" Command="{Binding NavigateSettingsPingRetryCommand}" />
                        <Button Content="ntfy" Style="{StaticResource NavigationSubButtonStyle}" Command="{Binding NavigateSettingsNtfyCommand}" />
                        <Button Content="E-posta / SMTP" Style="{StaticResource NavigationSubButtonStyle}" Command="{Binding NavigateSettingsEmailSmtpCommand}" />
                        <Button Content="E-posta Alıcıları" Style="{StaticResource NavigationSubButtonStyle}" Command="{Binding NavigateSettingsRecipientsCommand}" />
                        <Button Content="Bildirim Şablonları" Style="{StaticResource NavigationSubButtonStyle}" Command="{Binding NavigateSettingsTemplatesCommand}" />
                        <Button Content="Veri Saklama" Style="{StaticResource NavigationSubButtonStyle}" Command="{Binding NavigateSettingsRetentionCommand}" />
                        <Button Content="Gelişmiş" Style="{StaticResource NavigationSubButtonStyle}" Command="{Binding NavigateSettingsAdvancedCommand}" />
                        <Button Content="Sistem Durumu" Style="{StaticResource NavigationSubButtonStyle}" Command="{Binding NavigateSettingsReadinessCommand}" />
                    </StackPanel>
                </StackPanel>

                <Border DockPanel.Dock="Bottom"
                        Margin="12"
                        Padding="10"
                        CornerRadius="8"
                        Background="#1D2B42"
                        Visibility="{Binding IsNavigationCollapsed, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <StackPanel>
                        <TextBlock Text="Veritabanı" Foreground="#A7B2C4" FontSize="11" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding DatabaseLocation}" Foreground="#E5E7EB" FontSize="11" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource PanelSurfaceStyle}" Padding="18,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel MaxWidth="560">
                        <TextBlock Text="{Binding SectionTitle}" Style="{StaticResource ShellTitleTextStyle}" />
                        <TextBlock Text="{Binding SectionSubtitle}" Style="{StaticResource ShellSubtitleTextStyle}" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" MaxWidth="720">
                        <Border Style="{StaticResource TopMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="İzleme hizmeti" Style="{StaticResource MicroLabelTextStyle}" />
                                <TextBlock Text="{Binding WorkerHealthText}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource TopMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="Son kontrol" Style="{StaticResource MicroLabelTextStyle}" />
                                <TextBlock Text="{Binding WorkerLastScheduledPingText}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource TopMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="Aktif cihaz" Style="{StaticResource MicroLabelTextStyle}" />
                                <TextBlock Text="{Binding ActiveDeviceCount}" FontSize="18" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource TopMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="Erişilemiyor" Style="{StaticResource MicroLabelTextStyle}" />
                                <TextBlock Text="{Binding UnavailableDeviceCount}" FontSize="18" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource TopMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="Susturulan" Style="{StaticResource MicroLabelTextStyle}" />
                                <TextBlock Text="{Binding MutedDeviceCount}" FontSize="18" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource TopMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="Duraklatılan" Style="{StaticResource MicroLabelTextStyle}" />
                                <TextBlock Text="{Binding PausedDeviceCount}" FontSize="18" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource TopMetricStyle}">
                            <StackPanel>
                                <TextBlock Text="Bildirim" Style="{StaticResource MicroLabelTextStyle}" />
                                <TextBlock Text="{Binding PendingOrFailedNotificationCount}" FontSize="18" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Style="{StaticResource WarningNoticeStyle}"
                    Visibility="{Binding IsWorkerServiceStopped, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="İzleme hizmeti çalışmıyor. Otomatik kontroller ve bildirimler gerçekleştirilmeyecek."
                               Foreground="{StaticResource ShellWarningBrush}"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Sistem durumunu aç"
                            Command="{Binding NavigateSettingsReadinessCommand}"
                            Style="{StaticResource SecondaryToolbarButtonStyle}"
                            Margin="12,0,0,0" />
                </Grid>
            </Border>

            <Grid Grid.Row="2">
                <ScrollViewer Visibility="{Binding IsDashboardSection, Converter={StaticResource BooleanToVisibilityConverter}}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <WrapPanel>
                            <ItemsControl ItemsSource="{Binding SummaryCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource MetricTileStyle}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="5" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Background="{Binding AccentColor}" CornerRadius="4" />
                                                <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Title}" Style="{StaticResource MicroLabelTextStyle}" />
                                                    <TextBlock Text="{Binding Value}" FontSize="22" FontWeight="Bold" Margin="0,3,0,0" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </WrapPanel>

                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelSectionStyle}" Margin="0,0,12,14">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="En uzun süredir erişilemeyen cihazlar" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <DataGrid ItemsSource="{Binding OpenOutages}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" MaxHeight="260">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Cihaz adı" Binding="{Binding DeviceName}" Width="2*" MinWidth="190" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                            <DataGridTextColumn Header="IP adresi" Binding="{Binding IpAddress}" Width="135" MinWidth="135" ElementStyle="{StaticResource IpAddressCellTextStyle}" />
                                            <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="130" />
                                            <DataGridTextColumn Header="Kesinti başlangıcı" Binding="{Binding StartedAtText}" Width="150" />
                                            <DataGridTextColumn Header="Toplam süre" Binding="{Binding DurationText}" Width="95" />
                                            <DataGridTextColumn Header="Bildirim durumu" Binding="{Binding StatusText}" Width="120" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource PanelSectionStyle}">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="En düşük uptime değerleri" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <DataGrid ItemsSource="{Binding LowAvailabilityDevices}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" MaxHeight="260">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="2*" MinWidth="160" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                            <DataGridTextColumn Header="IP adresi" Binding="{Binding IpAddress}" Width="135" MinWidth="135" ElementStyle="{StaticResource IpAddressCellTextStyle}" />
                                            <DataGridTextColumn Header="30 gün" Binding="{Binding Availability30DaysText}" Width="90" />
                                            <DataGridTextColumn Header="Durum" Binding="{Binding LastStatusText}" Width="140" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelSectionStyle}" Margin="0,0,12,0">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="Yakında süresi dolacak susturmalar" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <DataGrid ItemsSource="{Binding Devices}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" MaxHeight="230">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Cihaz" Binding="{Binding Name}" Width="2*" MinWidth="180" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                            <DataGridTextColumn Header="IP adresi" Binding="{Binding IpAddress}" Width="135" MinWidth="135" ElementStyle="{StaticResource IpAddressCellTextStyle}" />
                                            <DataGridTextColumn Header="Durum" Binding="{Binding SuppressionText}" Width="220" />
                                            <DataGridTextColumn Header="Neden" Binding="{Binding SuppressionReason}" Width="160" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </DockPanel>
                            </Border>

                            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PanelSectionStyle}">
                                <StackPanel>
                                    <TextBlock Text="Bildirim kuyruğu özeti" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />
                                    <WrapPanel>
                                        <Border Style="{StaticResource TopMetricStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Bekleyen" Style="{StaticResource MicroLabelTextStyle}" />
                                                <TextBlock Text="{Binding PendingNotificationCount}" FontSize="20" FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource TopMetricStyle}">
                                            <StackPanel>
                                                <TextBlock Text="Başarısız" Style="{StaticResource MicroLabelTextStyle}" />
                                                <TextBlock Text="{Binding FailedNotificationCount}" FontSize="20" FontWeight="Bold" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>
                                    <TextBlock Text="Bildirim gönderimi izleme hizmetinin sorumluluğundadır. Arayüz yalnızca kuyruğu gösterir ve kullanıcı onaylı yeniden deneme işlemi başlatır."
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <Grid Visibility="{Binding IsDevicesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource PanelSectionStyle}">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Left" Margin="0,0,14,0">
                                <TextBlock Text="Cihazlar" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ActiveDeviceFilterSummaryText}" Style="{StaticResource BodyMutedTextStyle}" FontSize="12" />
                            </StackPanel>
                            <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button Content="+ Cihaz Ekle"
                                        Command="{Binding NavigateDeviceEditCommand}"
                                        Style="{StaticResource ToolbarButtonStyle}"
                                        ToolTip="Yeni cihaz ekle" />
                                <Button Content="{Binding PingSelectedDevicesText}"
                                        Command="{Binding PingSelectedDevicesBulkCommand}"
                                        CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        ToolTip="Seçili cihazlara manuel ping at" />
                                <Button Content="⏱ Tüm Aktiflere Ping At"
                                        Command="{Binding PingAllCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        ToolTip="Tüm aktif cihazlara manuel ping at" />
                                <Button Content="⏱ Listelenenlere Ping At"
                                        Command="{Binding PingFilteredDevicesCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        ToolTip="Geçerli filtrelerle listelenen cihazlara ping at" />
                                <Button Content="CSV İçe Aktar"
                                        Command="{Binding ImportDevicesCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        ToolTip="CSV dosyası seç ve içe aktarma önizlemesi oluştur" />
                                <Button Content="CSV Dışa Aktar"
                                        Command="{Binding ExportDevicesCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        ToolTip="Seçilen CSV kapsamını dosyaya kaydet" />
                                <Button Content="Yenile"
                                        Command="{Binding RefreshDevicesCommand}"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                <Menu Margin="0,0,8,8"
                                      VerticalAlignment="Center"
                                      Background="{StaticResource ShellSurfaceBrush}">
                                    <MenuItem Header="Diğer İşlemler" Padding="12,7">
                                        <MenuItem Header="Filtreleri Temizle" Command="{Binding ClearDeviceFiltersCommand}" />
                                        <Separator />
                                        <MenuItem Header="CSV Önizlemeyi Uygula" Command="{Binding ApplyCsvImportCommand}" />
                                        <MenuItem Header="CSV Şablonu Oluştur" Command="{Binding CreateCsvTemplateCommand}" />
                                        <Separator />
                                        <MenuItem Header="Seçilenleri Gruba Ata" Command="{Binding AssignSelectedDevicesToGroupCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" />
                                        <MenuItem Header="Otomatik Kontrolü Aç" Command="{Binding EnableAutoCheckSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" />
                                        <MenuItem Header="Otomatik Kontrolü Kapat" Command="{Binding DisableAutoCheckSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" />
                                        <MenuItem Header="Bildirimleri Sustur" Command="{Binding MuteNotificationsSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" />
                                        <MenuItem Header="İzlemeyi Geçici Durdur" Command="{Binding PauseMonitoringSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" />
                                        <MenuItem Header="Susturmayı Kaldır / İzlemeyi Devam Ettir" Command="{Binding ClearSuppressionSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" />
                                        <MenuItem Header="Pasif Yap" Command="{Binding DeactivateSelectedDevicesCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" />
                                        <MenuItem Header="Seçilenleri Sil" Command="{Binding DeleteSelectedDevicesBulkCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" />
                                    </MenuItem>
                                </Menu>
                                <Button Content="Kolonları Yönet"
                                        x:Name="DeviceColumnsButton"
                                        Style="{StaticResource SecondaryToolbarButtonStyle}"
                                        ToolTip="Cihaz listesinde gösterilecek kolonları seçin" />
                            </WrapPanel>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource PanelSectionStyle}">
                        <StackPanel>
                            <WrapPanel>
                                <StackPanel Width="260" MinWidth="220" Margin="0,0,10,0">
                                    <TextBlock Text="Cihaz adı veya IP" Style="{StaticResource FormFieldLabelStyle}" />
                                    <TextBox Text="{Binding DeviceSearchText, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                </StackPanel>
                                <StackPanel Width="180" MinWidth="150" Margin="0,0,10,0">
                                    <TextBlock Text="Cihaz tipi" Style="{StaticResource FormFieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding DeviceTypeFilterOptions}" SelectedItem="{Binding DeviceTypeFilter}" Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Width="190" MinWidth="150" Margin="0,0,10,0">
                                    <TextBlock Text="Grup" Style="{StaticResource FormFieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding DeviceGroupFilterOptions}" SelectedItem="{Binding DeviceGroupFilter}" Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Width="180" MinWidth="150" Margin="0,0,10,0">
                                    <TextBlock Text="Durum" Style="{StaticResource FormFieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding DeviceStatusFilterOptions}" SelectedItem="{Binding DeviceStatusFilter}" Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Width="210" MinWidth="180" Margin="0,0,10,0">
                                    <TextBlock Text="CSV dışa aktarma kapsamı" Style="{StaticResource FormFieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding CsvExportScopeOptions}" SelectedItem="{Binding CsvExportScope}" Style="{StaticResource FormComboBoxStyle}" />
                                </StackPanel>
                            </WrapPanel>
                            <WrapPanel Margin="0,2,0,0">
                                <ComboBox Width="210" ItemsSource="{Binding AutoCheckFilterOptions}" SelectedItem="{Binding AutoCheckFilter}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,8,8" />
                                <ComboBox Width="220" ItemsSource="{Binding SuppressionFilterOptions}" SelectedItem="{Binding SuppressionFilter}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,8,8" />
                                <ComboBox Width="170" ItemsSource="{Binding UptimeRangeFilterOptions}" SelectedItem="{Binding UptimeRangeFilter}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,8,8" />
                                <ComboBox Width="210" ItemsSource="{Binding LastCheckRangeFilterOptions}" SelectedItem="{Binding LastCheckRangeFilter}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,8,8" />
                                <ComboBox Width="170" ItemsSource="{Binding CriticalFilterOptions}" SelectedItem="{Binding CriticalFilter}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,8,8" />
                                <ComboBox Width="170" ItemsSource="{Binding DeviceDeletedFilterOptions}" SelectedItem="{Binding DeletedDeviceFilter}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,8,8" />
                                <CheckBox Content="Yalnızca sorunlu cihazlar" IsChecked="{Binding DeviceOnlyProblematic}" VerticalAlignment="Center" Margin="0,0,12,8" />
                                <ComboBox Width="220" ItemsSource="{Binding CsvImportModeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding CsvImportMode}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,8,8" ToolTip="CSV içe aktarma modu" />
                                <ComboBox Width="240" ItemsSource="{Binding CsvImportScopeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding CsvImportScope}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,8,8" ToolTip="CSV eşitleme kapsamı" />
                                <ComboBox Width="180" ItemsSource="{Binding DeviceGroupOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding CsvImportGroupId}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,8,8" ToolTip="Grup kapsamlı eşitleme için seçili grup" />
                                <TextBlock Text="{Binding CsvImportPreviewSummary}" Style="{StaticResource BodyMutedTextStyle}" MaxWidth="520" Margin="0,6,8,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="0">
                                <ColumnDefinition.Style>
                                    <Style TargetType="ColumnDefinition">
                                        <Setter Property="Width" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ShowDeviceFormPane}" Value="True">
                                                <Setter Property="Width" Value="480" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ColumnDefinition.Style>
                            </ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <Grid Grid.Column="0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource InlineNoticeStyle}" Visibility="{Binding HasSelectedDevices, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left" Text="{Binding SelectedDeviceCountText}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,16,0" />
                                    <WrapPanel>
                                        <Button Content="Ping at" Command="{Binding PingSelectedDevicesBulkCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SmallActionButtonStyle}" />
                                        <ComboBox Width="180" ItemsSource="{Binding DeviceGroupOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding BulkTargetGroupId}" Style="{StaticResource ModernComboBoxStyle}" Margin="0,0,6,6" />
                                        <Button Content="Gruba ata" Command="{Binding AssignSelectedDevicesToGroupCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SmallActionButtonStyle}" />
                                        <Button Content="Otomatik kontrolü aç" Command="{Binding EnableAutoCheckSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SmallActionButtonStyle}" />
                                        <Button Content="Otomatik kontrolü kapat" Command="{Binding DisableAutoCheckSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SmallActionButtonStyle}" />
                                        <TextBox Width="70" Text="{Binding BulkSuppressionDurationHours}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,6,6" ToolTip="Süre, saat olarak girilir. Sıfır süresiz anlamına gelir." />
                                        <TextBox Width="160" Text="{Binding BulkSuppressionReason}" Style="{StaticResource ModernTextBoxStyle}" Margin="0,0,6,6" ToolTip="Bakım, cihaz değişimi veya hat problemi gibi neden yazın." />
                                        <Button Content="Bildirimleri sustur" Command="{Binding MuteNotificationsSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SmallActionButtonStyle}" />
                                        <Button Content="İzlemeyi durdur" Command="{Binding PauseMonitoringSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SmallActionButtonStyle}" />
                                        <Button Content="Susturmayı kaldır" Command="{Binding ClearSuppressionSelectedCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SmallActionButtonStyle}" />
                                        <Button Content="Pasif yap" Command="{Binding DeactivateSelectedDevicesCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SmallActionButtonStyle}" />
                                        <Button Content="Sil" Command="{Binding DeleteSelectedDevicesBulkCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource DangerToolbarButtonStyle}" />
                                        <Button Content="Geri yükle" Command="{Binding RestoreSelectedDevicesBulkCommand}" CommandParameter="{Binding SelectedItems, ElementName=DevicesGrid}" Style="{StaticResource SmallActionButtonStyle}" />
                                    </WrapPanel>
                                </DockPanel>
                            </Border>

                            <DataGrid x:Name="DevicesGrid"
                                      Grid.Row="1"
                                      ItemsSource="{Binding DevicesView}"
                                      SelectedItem="{Binding SelectedDevice}"
                                      Style="{StaticResource ModernDataGridStyle}"
                                      ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}"
                                      RowBackground="White"
                                      AlternatingRowBackground="#F8FAFC"
                                      infra:DataGridLayoutBehavior.StorageKey="DevicesGrid.v2"
                                      infra:DataGridLayoutBehavior.ColumnChooserButtonName="DeviceColumnsButton">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Header="Seçim" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="58" MinWidth="58" />
                                    <DataGridTemplateColumn Header="Cihaz adı" Width="2.3*" MinWidth="260">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2,5">
                                                    <TextBlock Text="{Binding Name}" Style="{StaticResource ReadableCellTextStyle}" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding HealthHintText}" Style="{StaticResource BodyMutedTextStyle}" FontSize="12" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="IP adresi" Binding="{Binding IpAddress}" Width="145" MinWidth="145" ElementStyle="{StaticResource IpAddressCellTextStyle}" />
                                    <DataGridTextColumn Header="Cihaz tipi" Binding="{Binding DeviceTypeText}" Width="130" MinWidth="110" />
                                    <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="150" MinWidth="120" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                    <DataGridTemplateColumn Header="Son durum" Width="190" MinWidth="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="2,4">
                                                    <Border Style="{StaticResource StatusPillStyle}" Background="{Binding LastStatus, Converter={StaticResource StatusBackgroundConverter}}">
                                                        <TextBlock Foreground="{Binding LastStatus, Converter={StaticResource StatusForegroundConverter}}" FontWeight="SemiBold" TextWrapping="Wrap">
                                                            <Run Text="● " />
                                                            <Run Text="{Binding LastStatusText, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </Border>
                                                    <TextBlock Text="{Binding SuppressionText}" FontSize="12" Foreground="{StaticResource ShellMutedTextBrush}" TextWrapping="Wrap" Margin="2,3,0,0" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Gecikme" Binding="{Binding LastLatencyText}" Width="90" />
                                    <DataGridTextColumn Header="Son kontrol" Binding="{Binding LastCheckedAtText}" Width="150" />
                                    <DataGridTextColumn Header="Son başarılı kontrol" Binding="{Binding LastSuccessfulCheckAtText}" Width="160" />
                                    <DataGridTextColumn Header="Kesinti süresi" Binding="{Binding LastFailureAtText}" Width="150" />
                                    <DataGridTextColumn Header="Uptime" Binding="{Binding Uptime30DaysText}" Width="92" />
                                    <DataGridTextColumn Header="Otomatik kontrol" Binding="{Binding AutoCheckText}" Width="130" />
                                    <DataGridTextColumn Header="Bildirim durumu" Binding="{Binding SuppressionText}" Width="175" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                    <DataGridTemplateColumn Header="İşlemler" Width="230" MinWidth="210">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <WrapPanel VerticalAlignment="Center">
                                                    <Button Content="Ping At"
                                                            Command="{Binding DataContext.PingDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Bu cihaza manuel ping at" />
                                                    <Button Content="Detayı Aç"
                                                            Command="{Binding DataContext.EditDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource SmallActionButtonStyle}"
                                                            ToolTip="Cihaz bilgilerini düzenle" />
                                                    <Menu Margin="0,0,6,6"
                                                          VerticalAlignment="Center"
                                                          Background="{StaticResource ShellSurfaceBrush}"
                                                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}">
                                                        <MenuItem Header="..." Padding="8,4">
                                                            <MenuItem Header="Düzenle"
                                                                      Command="{Binding Tag.EditDeviceCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                                      CommandParameter="{Binding}" />
                                                            <MenuItem Header="Sil"
                                                                      Command="{Binding Tag.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                                      CommandParameter="{Binding}" />
                                                            <MenuItem Header="Geri Yükle"
                                                                      Command="{Binding Tag.RestoreDeviceCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                                      CommandParameter="{Binding}" />
                                                            <Separator />
                                                            <MenuItem Header="Bildirimleri Sustur"
                                                                      Command="{Binding Tag.SuppressNotificationsCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                                      CommandParameter="{Binding}" />
                                                            <MenuItem Header="İzlemeyi Geçici Durdur"
                                                                      Command="{Binding Tag.PauseMonitoringCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                                      CommandParameter="{Binding}" />
                                                            <MenuItem Header="Susturmayı Kaldır"
                                                                      Command="{Binding Tag.RemoveSuppressionCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                                      CommandParameter="{Binding}" />
                                                            <MenuItem Header="İzlemeyi Devam Ettir"
                                                                      Command="{Binding Tag.ResumeMonitoringCommand, RelativeSource={RelativeSource AncestorType=Menu}}"
                                                                      CommandParameter="{Binding}" />
                                                        </MenuItem>
                                                    </Menu>
                                                </WrapPanel>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <TextBlock Grid.Row="1"
                                       Text="Filtrelerle eşleşen cihaz bulunamadı. Filtreleri temizleyebilir veya yeni cihaz ekleyebilirsiniz."
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasNoFilteredDevices, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>

                        <Border Grid.Column="1"
                                Style="{StaticResource PanelSurfaceStyle}"
                                Margin="14,0,0,0"
                                Visibility="{Binding ShowDeviceFormPane, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,12">
                                        <Button DockPanel.Dock="Right" Content="Kapat" Command="{Binding CloseDeviceFormCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                        <TextBlock Text="{Binding DeviceFormTitle}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" />
                                    </DockPanel>
                                    <TextBlock Text="Genel bilgiler" FontWeight="SemiBold" Margin="0,0,0,8" />
                                    <TextBlock Text="Cihaz adı" Style="{StaticResource FormFieldLabelStyle}" />
                                    <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                    <TextBlock Text="IPv4 adresi" Style="{StaticResource FormFieldLabelStyle}" />
                                    <TextBox Text="{Binding FormIpAddress, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Cihaz tipi" Style="{StaticResource FormFieldLabelStyle}" />
                                            <ComboBox ItemsSource="{Binding DeviceTypeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding FormDeviceType}" Style="{StaticResource FormComboBoxStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Grup" Style="{StaticResource FormFieldLabelStyle}" />
                                            <ComboBox ItemsSource="{Binding DeviceGroupOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding FormGroupId}" Style="{StaticResource FormComboBoxStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Açıklama" Style="{StaticResource FormFieldLabelStyle}" />
                                    <TextBox Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" VerticalScrollBarVisibility="Auto" />
                                    <TextBlock Text="İzleme politikası" FontWeight="SemiBold" Margin="0,8,0,8" />
                                    <CheckBox Content="Otomatik kontrole dahil et" IsChecked="{Binding FormAutoCheckEnabled}" Margin="0,0,0,10" />
                                    <TextBlock Text="Ping planı veya politika" Style="{StaticResource FormFieldLabelStyle}" />
                                    <ComboBox ItemsSource="{Binding SchedulePlanOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding FormDefaultSchedulePlanId}" Style="{StaticResource FormComboBoxStyle}" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Kontrol aralığı, saniye" Style="{StaticResource FormFieldLabelStyle}" />
                                            <TextBox Text="{Binding FormCheckIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Zaman aşımı, ms" Style="{StaticResource FormFieldLabelStyle}" />
                                            <TextBox Text="{Binding FormPingTimeoutMs, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Yeniden deneme aralığı, saniye" Style="{StaticResource FormFieldLabelStyle}" />
                                            <TextBox Text="{Binding FormFailureRetryIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Yeniden deneme sınırı" Style="{StaticResource FormFieldLabelStyle}" />
                                            <TextBox Text="{Binding FormFailureRetryLimit, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="Kesin sorun eşiği" Style="{StaticResource FormFieldLabelStyle}" />
                                    <TextBox Text="{Binding FormFailureThreshold, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                    <WrapPanel Margin="0,4,0,0">
                                        <CheckBox Content="Kritik cihaz" IsChecked="{Binding FormIsCritical}" Margin="0,0,14,8" />
                                        <CheckBox Content="Etkin kayıt" IsChecked="{Binding FormIsActive}" Margin="0,0,14,8" />
                                    </WrapPanel>
                                    <WrapPanel HorizontalAlignment="Right" Margin="0,10,0,0">
                                        <Button Content="Temizle" Command="{Binding ClearDeviceFormCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                        <Button Content="{Binding DeviceFormActionText}" Command="{Binding SaveDeviceCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                                    </WrapPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Grid>

                <Grid Visibility="{Binding IsGroupsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="380" />
                    </Grid.ColumnDefinitions>
                    <DataGrid ItemsSource="{Binding DeviceGroups}" SelectedItem="{Binding SelectedGroup}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" Margin="0,0,14,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Grup adı" Binding="{Binding Name}" Width="1.5*" MinWidth="180" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                            <DataGridTextColumn Header="Cihaz sayısı" Binding="{Binding DeviceCountText}" Width="100" />
                            <DataGridTextColumn Header="30 gün uptime" Binding="{Binding Availability30DaysText}" Width="120" />
                            <DataGridTextColumn Header="Varsayılan politika" Binding="{Binding DefaultPolicyText}" Width="2*" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Column="1" Style="{StaticResource PanelSurfaceStyle}">
                        <StackPanel>
                            <TextBlock Text="{Binding GroupFormTitle}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                            <TextBlock Text="Grup adı" Style="{StaticResource FormFieldLabelStyle}" />
                            <TextBox Text="{Binding GroupFormName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                            <TextBlock Text="Açıklama" Style="{StaticResource FormFieldLabelStyle}" />
                            <TextBox Text="{Binding GroupFormDescription, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="72" />
                            <TextBlock Text="Varsayılan plan" Style="{StaticResource FormFieldLabelStyle}" />
                            <ComboBox ItemsSource="{Binding SchedulePlanOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding GroupFormDefaultSchedulePlanId}" Style="{StaticResource FormComboBoxStyle}" />
                            <TextBlock Text="Varsayılan kontrol aralığı, saniye" Style="{StaticResource FormFieldLabelStyle}" />
                            <TextBox Text="{Binding GroupFormDefaultCheckIntervalSeconds}" Style="{StaticResource FormTextBoxStyle}" />
                            <WrapPanel HorizontalAlignment="Right">
                                <Button Content="Yeni grup" Command="{Binding ClearGroupFormCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                                <Button Content="{Binding GroupFormActionText}" Command="{Binding SaveGroupCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                                <Button Content="Sil" Command="{Binding DeleteSelectedGroupCommand}" Style="{StaticResource DangerToolbarButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding IsSchedulesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource PanelSectionStyle}">
                        <WrapPanel>
                            <Button Content="Planı çalıştır" Command="{Binding RunSelectedSchedulePlanCommand}" Style="{StaticResource ToolbarButtonStyle}" />
                            <Button Content="Yenile" Command="{Binding RefreshDevicesCommand}" Style="{StaticResource SecondaryToolbarButtonStyle}" />
                        </WrapPanel>
                    </Border>
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="430" />
                        </Grid.ColumnDefinitions>
                        <DataGrid ItemsSource="{Binding SchedulePlans}" SelectedItem="{Binding SelectedSchedulePlan}" Style="{StaticResource ModernDataGridStyle}" ColumnHeaderStyle="{StaticResource ModernDataGridHeaderStyle}" Margin="0,0,14,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Plan adı" Binding="{Binding Name}" Width="1.5*" MinWidth="180" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                <DataGridTextColumn Header="Hedef" Binding="{Binding TargetDisplayName}" Width="1.5*" MinWidth="160" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                <DataGridTextColumn Header="Plan" Binding="{Binding ScheduleModeText}" Width="140" />
                                <DataGridTextColumn Header="Zamanlama" Binding="{Binding IntervalText}" Width="170" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                <DataGridTextColumn Header="Erişilemeyen kontrol" Binding="{Binding OfflineRecheckIntervalText}" Width="150" />
                                <DataGridTextColumn Header="Yeniden deneme" Binding="{Binding RetrySummaryText}" Width="170" ElementStyle="{StaticResource ReadableCellTextStyle}" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding IsActiveText}" Width="100" />
                                <DataGridTextColumn Header="Son çalışma" Binding="{Binding LastRunAtText}" Width="150" />
                                <DataGridTextColumn Header="Sonraki çalışma" Binding="{Binding NextRunAtText}" Width="150" />
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Column="1" Style="{StaticResource PanelSurfaceStyle}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding PlanFormTitle}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="Plan adı" Style="{StaticResource FormFieldLabelStyle}" />
                                <TextBox Text="{Binding PlanFormName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                <TextBlock Text="Hedef türü" Style="{StaticResource FormFieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding PlanTargetTypeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding PlanFormTargetType}" Style="{StaticResource FormComboBoxStyle}" />
                                <TextBlock Text="Hedef" Style="{StaticResource FormFieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding PlanTargetOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding PlanFormTargetValue}" Style="{StaticResource FormComboBoxStyle}" />
                                <TextBlock Text="Normal kontrol" FontWeight="SemiBold" Margin="0,10,0,8" />
                                <TextBlock Text="Zamanlama modu" Style="{StaticResource FormFieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding ScheduleModeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding PlanFormScheduleMode}" Style="{StaticResource FormComboBoxStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Sıklık" Style="{StaticResource FormFieldLabelStyle}" />
                                        <TextBox Text="{Binding PlanFormFrequencyValue}" Style="{StaticResource FormTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Birim" Style="{StaticResource FormFieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding FrequencyUnitOptions}" SelectedItem="{Binding PlanFormFrequencyUnit}" Style="{StaticResource FormComboBoxStyle}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Günlük kontrol sayısı" Style="{StaticResource FormFieldLabelStyle}" />
                                <TextBox Text="{Binding PlanFormTimesPerDay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" ToolTip="1 ile 48 arasında bir değer girin. Günde belirli sayıda modunda kullanılır." />
                                <TextBlock Text="Özel saatler" Style="{StaticResource FormFieldLabelStyle}" />
                                <TextBox Text="{Binding PlanFormDailyTimes, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="54" ToolTip="08:00;12:00;16:00 gibi saatleri noktalı virgül veya satır sonuyla girin." />
                                <TextBlock Text="Haftalık günler" Style="{StaticResource FormFieldLabelStyle}" />
                                <TextBox Text="{Binding PlanFormSelectedWeekDays, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" ToolTip="Monday,Tuesday veya Pazartesi,Salı biçiminde girilebilir." />
                                <TextBlock Text="Başarısızlık doğrulama" FontWeight="SemiBold" Margin="0,10,0,8" />
                                <CheckBox Content="Hızlı yeniden deneme etkin" IsChecked="{Binding PlanFormFailureRetryEnabled}" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Yeniden deneme sayısı" Style="{StaticResource FormFieldLabelStyle}" />
                                        <TextBox Text="{Binding PlanFormConfirmationRetryCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Yeniden deneme aralığı, saniye" Style="{StaticResource FormFieldLabelStyle}" />
                                        <TextBox Text="{Binding PlanFormConfirmationRetryIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Erişilemeyen cihaz kontrolü" FontWeight="SemiBold" Margin="0,10,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Aralık" Style="{StaticResource FormFieldLabelStyle}" />
                                        <TextBox Text="{Binding PlanFormOfflineRecheckIntervalValue, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Birim" Style="{StaticResource FormFieldLabelStyle}" />
                                        <ComboBox ItemsSource="{Binding FrequencyUnitOptions}" SelectedItem="{Binding PlanFormOfflineRecheckIntervalUnit}" Style="{StaticResource FormComboBoxStyle}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Kaçırılmış kontroller" Style="{StaticResource FormFieldLabelStyle}" />
                                <ComboBox ItemsSource="{Binding MissedRunPolicyOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding PlanFormMissedRunPolicy}" Style="{StaticResource FormComboBoxStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0">
                                        <TextBlock Text="Zaman aşımı, ms" Style="{StaticResource FormFieldLabelStyle}" />
                                        <TextBox Text="{Binding PlanFormTimeoutMs, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock Text="Paralel sınır" Style="{StaticResource FormFieldLabelStyle}" />
                                        <TextBox Text="{Binding PlanFormMaxParallelism, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource FormTextBoxStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Eşik" Style="{StaticResource FormFieldLabelStyle}" />

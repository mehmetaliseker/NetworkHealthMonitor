                    <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                        <WrapPanel VerticalAlignment="Center">
                            <DatePicker Width="140" SelectedDate="{Binding LogStartDate}" />
                            <DatePicker Width="140" SelectedDate="{Binding LogEndDate}" Margin="8,0,0,0" />
                            <TextBox Width="170" Text="{Binding LogDeviceNameFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="Cihaz adı" Margin="8,0,0,0" />
                            <TextBox Width="135" Text="{Binding LogIpAddressFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="IP adresi" Margin="8,0,0,0" />
                            <ComboBox Width="135" ItemsSource="{Binding DeviceTypeFilterOptions}" SelectedItem="{Binding LogDeviceTypeFilter}" Margin="8,0,0,0" />
                            <ComboBox Width="145" ItemsSource="{Binding DeviceStatusFilterOptions}" SelectedItem="{Binding LogStatusFilter}" Margin="8,0,0,0" />
                            <ComboBox Width="145" ItemsSource="{Binding DeviceGroupFilterOptions}" SelectedItem="{Binding LogGroupFilter}" Margin="8,0,0,0" />
                            <ComboBox Width="145" ItemsSource="{Binding TriggerFilterOptions}" SelectedItem="{Binding LogTriggerFilter}" Margin="8,0,0,0" />
                            <TextBox Width="150" Text="{Binding LogPlanNameFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="Plan adı" Margin="8,0,0,0" />
                            <CheckBox Content="Sadece riskli / yanıt yok" IsChecked="{Binding LogOnlyUnreachable}" VerticalAlignment="Center" Margin="10,0,0,0" />
                            <Button Content="Filtrele" Command="{Binding RefreshLogsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="CSV'ye aktar" Command="{Binding ExportLogsCommand}" />
                            <Button Content="Eski Logları Temizle" Command="{Binding ClearOldLogsCommand}" Style="{StaticResource DangerButtonStyle}" />
                            <Button Content="Tüm Logları Temizle" Command="{Binding ClearLogsCommand}" Style="{StaticResource DangerButtonStyle}" />
                        </WrapPanel>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding LogsView}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih/Saat" Binding="{Binding CheckedAtText}" Width="150" />
                            <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="1.1*" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                            <DataGridTextColumn Header="Tip" Binding="{Binding DeviceTypeText}" Width="110" />
                            <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="120" />
                            <DataGridTemplateColumn Header="Durum" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status, Converter={StaticResource StatusBackgroundConverter}}"
                                                CornerRadius="6"
                                                Padding="8,4"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusForegroundConverter}}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Gecikme" Binding="{Binding LatencyText}" Width="85" />
                            <DataGridTextColumn Header="Kaynak" Binding="{Binding TriggerTypeText}" Width="130" />
                            <DataGridTextColumn Header="Plan" Binding="{Binding SchedulePlanName}" Width="150" />
                            <DataGridTextColumn Header="Mesaj" Binding="{Binding ResponseOrErrorText}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <ScrollViewer Visibility="{Binding IsNotificationsSection, Converter={StaticResource BooleanToVisibilityConverter}}"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="ntfy Bildirim Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />

                                <TextBlock Text="Genel durum" FontSize="15" FontWeight="Bold" Margin="0,0,0,8" />
                                <CheckBox Content="ntfy bildirimleri aktif" IsChecked="{Binding NotificationEnabled}" FontWeight="SemiBold" Margin="0,0,0,12" />
                                <TextBlock Text="{Binding NotificationLastSuccessfulAtText, StringFormat=Son başarılı bildirim: {0}}"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           Margin="0,0,0,12" />

                                <Separator Margin="0,4,0,14" />
                                <TextBlock Text="Bağlantı ayarları" FontSize="15" FontWeight="Bold" Margin="0,0,0,10" />
                                <TextBlock Text="Sunucu adresi" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding NotificationBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                                <TextBlock Text="Konu" Style="{StaticResource FormLabelStyle}" />
                                <TextBox Text="{Binding NotificationTopic, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />
                                <TextBlock Text="Erişim anahtarı" Style="{StaticResource FormLabelStyle}" />
                                <PasswordBox infra:PasswordBoxAssistant.BoundPassword="{Binding NotificationAccessToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12" />

                                <Separator Margin="0,4,0,14" />
                                <TextBlock Text="Bildirim türleri" FontSize="15" FontWeight="Bold" Margin="0,0,0,10" />
                                <WrapPanel Margin="0,0,0,12">
                                    <CheckBox Content="Kesinti" IsChecked="{Binding NotificationNotifyOnDown}" Margin="0,0,14,0" />
                                    <CheckBox Content="Düzelme" IsChecked="{Binding NotificationNotifyOnRecovered}" Margin="0,0,14,0" />
                                    <CheckBox Content="IP adresi dahil" IsChecked="{Binding NotificationIncludeIpAddress}" />
                                </WrapPanel>

                                <Separator Margin="0,4,0,14" />
                                <TextBlock Text="Eşik ayarları" FontSize="15" FontWeight="Bold" Margin="0,0,0,10" />
                                <UniformGrid Columns="2" Margin="0,0,0,12">
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Text="Başarısızlık eşiği" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Text="{Binding NotificationDownFailureThreshold, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="8,0,0,8">
                                        <TextBlock Text="Düzelme eşiği" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Text="{Binding NotificationRecoverySuccessThreshold, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Text="Bildirim bekleme süresi (dk)" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Text="{Binding NotificationCooldownMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="8,0,0,8">
                                        <TextBlock Text="HTTP zaman aşımı (sn)" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Text="{Binding NotificationRequestTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="0,0,8,8">
                                        <TextBlock Text="Maksimum yeniden deneme" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Text="{Binding NotificationMaxRetryCount, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                    <StackPanel Margin="8,0,0,8">
                                        <TextBlock Text="İlk yeniden deneme gecikmesi (sn)" Style="{StaticResource FormLabelStyle}" />
                                        <TextBox Text="{Binding NotificationInitialRetryDelaySeconds, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </UniformGrid>

                                <Button Margin="0,0,0,10"
                                        Command="{Binding SendTestNotificationCommand}"
                                        IsEnabled="{Binding CanSendTestNotification}">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                            <Setter Property="Content" Value="Test bildirimi gönder" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsSendingTestNotification}" Value="True">
                                                    <Setter Property="Content" Value="Gönderiliyor…" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>

                                <Border Margin="0,0,0,10" Padding="12,10" CornerRadius="6" BorderThickness="1">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Setter Property="Background" Value="{StaticResource ErrorBannerBackgroundBrush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource ErrorBannerBorderBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding NotificationLastTestResult}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSendingTestNotification}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding NotificationLastTestTechnicalDetail}" Value="">
                                                    <Setter Property="Background" Value="{StaticResource SuccessBannerBackgroundBrush}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource SuccessBannerBorderBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding NotificationLastTestResult}" TextWrapping="Wrap" />
                                </Border>

                                <Expander Header="Teknik ayrıntıları göster"
                                          IsExpanded="{Binding NotificationShowTechnicalDetail, Mode=TwoWay}"
                                          Margin="0,0,0,4">
                                    <TextBlock Text="{Binding NotificationLastTestTechnicalDetail}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </Expander>
                                <WrapPanel Margin="0,10,0,0">
                                    <Button Content="Bildirim ayarlarını kaydet" Command="{Binding SaveSettingsCommand}" />
                                    <TextBlock Text="Değişikliklerin kalıcı olması için kaydedin."
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="10,0,0,0" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Bildirim kuyruğu" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                        <Border Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                            <WrapPanel>
                                <ComboBox Width="140" ItemsSource="{Binding OutboxStatusOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding OutboxStatusFilter}" />
                                <ComboBox Width="160" ItemsSource="{Binding OutboxEventTypeOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding OutboxEventTypeFilter}" Margin="8,0,0,0" />
                                <ComboBox Width="220" ItemsSource="{Binding DeviceOptions}" DisplayMemberPath="Label" SelectedValuePath="Value" SelectedValue="{Binding OutboxDeviceFilterId}" Margin="8,0,0,0" ToolTip="Cihaz filtresi" />
                                <DatePicker SelectedDate="{Binding OutboxStartDate}" Width="130" Margin="8,0,0,0" />
                                <DatePicker SelectedDate="{Binding OutboxEndDate}" Width="130" Margin="8,0,0,0" />
                                <Button Content="Yenile" Command="{Binding RefreshOutboxCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Seçili başarısızları yeniden dene" Command="{Binding RetrySelectedOutboxCommand}" CommandParameter="{Binding SelectedItems, ElementName=OutboxGrid}" />
                            </WrapPanel>
                        </Border>
                        <DataGrid x:Name="OutboxGrid"
                                  Height="420"
                                  ItemsSource="{Binding NotificationOutboxItems}"
                                  SelectedItem="{Binding SelectedNotificationOutboxItem}"
                                  SelectionMode="Extended"
                                  SelectionUnit="FullRow"
                                  AutoGenerateColumns="False"
                                  ScrollViewer.HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="" Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="42" />
                                <DataGridTextColumn Header="Durum" Binding="{Binding StatusText}" Width="100" />
                                <DataGridTextColumn Header="Bildirim türü" Binding="{Binding EventTypeText}" Width="130" />
                                <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="1.2*" />
                                <DataGridTextColumn Header="Kesinti" Binding="{Binding IncidentText}" Width="85" />
                                <DataGridTextColumn Header="Oluşturulma" Binding="{Binding CreatedAtText}" Width="145" />
                                <DataGridTextColumn Header="Gönderilme" Binding="{Binding SentAtText}" Width="145" />
                                <DataGridTextColumn Header="Deneme" Binding="{Binding AttemptCount}" Width="75" />
                                <DataGridTextColumn Header="Son deneme" Binding="{Binding LastAttemptAtText}" Width="145" />
                                <DataGridTextColumn Header="Sonraki deneme" Binding="{Binding NextAttemptAtText}" Width="145" />
                                <DataGridTextColumn Header="Son hata" Binding="{Binding LastError}" Width="2*" />
                                <DataGridTemplateColumn Header="İşlem" Width="210">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="Yeniden dene" Style="{StaticResource SmallButtonStyle}" Command="{Binding DataContext.RetryOutboxCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                                <Button Content="İptal" Style="{StaticResource SmallDangerButtonStyle}" Command="{Binding DataContext.CancelPendingOutboxCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                                <Button Content="Detay" Style="{StaticResource SmallSecondaryButtonStyle}" Command="{Binding DataContext.ShowOutboxDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer Visibility="{Binding IsSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Style="{StaticResource SectionBorderStyle}" MaxWidth="760" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Ping Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />
                            <TextBlock Text="Varsayılan ping zaman aşımı (ms)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding PingTimeoutMs, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Cihaza, gruba, tipe veya plana özel zaman aşımı yoksa kullanılır."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Varsayılan maksimum paralel ping sayısı" FontWeight="SemiBold" />
                            <TextBox Text="{Binding MaxParallelPings, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Toplu ve otomatik pinglerde aynı anda çalışacak en fazla ping sayısı."
                                     Margin="0,4,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Otomatik Kontrol Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="Global otomatik kontrol aralığı (dk)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding AutoCheckIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Cihaz özel aralığı 0 ve grup varsayılanı boşsa kullanılır."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="İzleme servisi kontrol sıklığı (sn)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding SchedulerPollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Planların zamanı gelmiş mi kontrol eden düşük maliyetli döngü sıklığı."
                                     Margin="0,4,0,12" />
                            <CheckBox Content="Global otomatik kontrol aktif"
                                      IsChecked="{Binding AutoCheckEnabled}"
                                      FontWeight="SemiBold"
                                      Margin="0,2,0,12" />
                            <TextBlock Text="Aktif planlar Windows servisi tarafından çalıştırılır; arayüz kapansa da izleme servisi çalışmaya devam eder."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                            <CheckBox Content="Windows'a giriş yaptığımda yönetim ekranını aç"
                                      IsChecked="{Binding OpenUiOnWindowsLogin}"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,4" />
                            <TextBlock Text="Bu seçenek yalnızca WPF yönetim ekranını açar; izleme servisi arayüz açılmadan arka planda çalışmaya devam eder."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Yeniden Deneme / Akıllı Kontrol Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="Varsayılan başarısızlık eşiği" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DefaultFailureThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Bu eşikten sonra cihaz takipte/şüpheli durumuna yaklaşır; tek hata kesin arıza sayılmaz."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Varsayılan hızlı yeniden deneme aralığı (sn)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DefaultFailureRetryIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Başarısız ping sonrası yalnız ilgili cihaz için uygulanacak kısa tekrar aralığı."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Varsayılan hızlı yeniden deneme limiti" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DefaultFailureRetryLimit, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hızlı yeniden deneme denemeleri bu limitten sonra normal politika akışına döner."
                                     Margin="0,4,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Bildirimler" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <Border Background="#EEF3FA"
                                    BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="12"
                                    Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="Bildirim ayarları Bildirimler ekranındadır."
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="ntfy bağlantısı, bildirim türleri, eşikler ve test bildirimi için sol menüden Bildirimler bölümünü açın."
                                               Foreground="{StaticResource MutedTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,10" />
                                    <Button Content="Bildirimlere git"
                                            Command="{Binding NavigateNotificationsCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            HorizontalAlignment="Left" />
                                </StackPanel>
                            </Border>

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="İzleme servisi sağlığı" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <TextBlock Text="{Binding WorkerHealthText, StringFormat=Durum: {0}}" />
                                <TextBlock Text="{Binding WorkerVersionText, StringFormat=Sürüm: {0}}" />
                                <TextBlock Text="{Binding WorkerStartedAtText, StringFormat=Başlangıç: {0}}" />
                                <TextBlock Text="{Binding WorkerLastSeenAtText, StringFormat=Son heartbeat: {0}}" />
                                <TextBlock Text="{Binding WorkerLastSchedulerCycleText, StringFormat=Son zamanlayıcı: {0}}" />
                                <TextBlock Text="{Binding WorkerLastScheduledPingText, StringFormat=Son ping: {0}}" />
                                <TextBlock Text="{Binding WorkerLastNotificationText, StringFormat=Son bildirim: {0}}" />
                                <TextBlock Text="{Binding PendingNotificationCount, StringFormat=Bekleyen bildirim: {0}}" />
                                <TextBlock Text="{Binding FailedNotificationCount, StringFormat=Başarısız bildirim: {0}}" />
                            </UniformGrid>
                            <Button Content="Log klasörünü aç" Command="{Binding OpenLogFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Tip Bazlı Politikalar" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                            <DataGrid ItemsSource="{Binding DeviceTypePolicies}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      Height="190"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ToolTip="Boş hücre = global varsayılan. Pozitif değer girilirse cihaz tipi varsayılanı olur.">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tip" Binding="{Binding DeviceTypeText}" IsReadOnly="True" Width="120" />
                                    <DataGridCheckBoxColumn Header="Oto" Binding="{Binding AutoCheckEnabled}" IsThreeState="True" Width="65" />
                                    <DataGridTextColumn Header="Aralık" Binding="{Binding DefaultCheckIntervalSeconds, TargetNullValue=''}" Width="80" />
                                    <DataGridTextColumn Header="Zaman aşımı" Binding="{Binding DefaultPingTimeoutMs, TargetNullValue=''}" Width="80" />
                                    <DataGridTextColumn Header="Yeniden deneme" Binding="{Binding DefaultFailureRetryIntervalSeconds, TargetNullValue=''}" Width="80" />
                                    <DataGridTextColumn Header="Limit" Binding="{Binding DefaultFailureRetryLimit, TargetNullValue=''}" Width="70" />
                                    <DataGridTextColumn Header="Eşik" Binding="{Binding DefaultFailureThreshold, TargetNullValue=''}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Log ve erişilebilirlik ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="Log saklama süresi (gün, 0 = süresiz)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding LogRetentionDays, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Eski ping logları manuel temizlikte bu süreye göre silinir."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Heartbeat toleransı (saniye)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding HeartbeatGraceSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="İzleme servisi heartbeat bu süreyi aşarsa izleme boşluğu Belirsiz kabul edilir."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Beklenen kontrol boşluğu katsayısı" FontWeight="SemiBold" />
                            <TextBox Text="{Binding ExpectedCheckGraceMultiplier, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Kontrol aralığının bu katı aşılırsa cihaz belirsiz kabul edilebilir."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Kesinti başlangıç politikası" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding DowntimeStartPolicyOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding DowntimeStartPolicy}"
                                      Margin="0,4,0,12" />
                            <TextBlock Text="Erişilebilirlik dönemi saklama (gün, 0 = süresiz)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding AvailabilityPeriodRetentionDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Kesinti saklama (gün, 0 = süresiz)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding IncidentRetentionDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Günlük özet saklama (gün, 0 = süresiz)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DailyAggregateRetentionDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Dışa Aktarma Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="CSV dışa aktarma klasörü" FontWeight="SemiBold" />
                            <TextBox Text="{Binding ExportDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Boş bırakılırsa dosya kaydetme penceresi son kullanılan Windows konumunu açar."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="CSV ayırıcı" FontWeight="SemiBold" />
                            <TextBox Text="{Binding CsvDelimiter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Türkiye Excel uyumu için varsayılan noktalı virgüldür."
                                     Margin="0,4,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Görünüm" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="Tema" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Theme}" Margin="0,4,0,12" />
                            <TextBlock Text="Veritabanı konumu" FontWeight="SemiBold" />
                            <Border BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    Padding="9,6"
                                    Margin="0,4,0,16">
                                <TextBlock Text="{Binding DatabaseLocation, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding DatabaseLocation, Mode=OneWay}" />
                            </Border>
                            <WrapPanel>
                                <Button Content="Ayarları Kaydet" Command="{Binding SaveSettingsCommand}" />
                                <Button Content="Ayarları Sıfırla" Command="{Binding ResetSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                            <Separator Margin="0,18,0,14" />
                            <TextBlock Text="Bakım" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                            <WrapPanel>
                                <Button Content="Veritabanını Yedekle" Command="{Binding BackupDatabaseCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Veritabanını Geri Yükle" Command="{Binding RestoreDatabaseCommand}" Style="{StaticResource DangerButtonStyle}" />
                                <Button Content="Veritabanını Optimize Et" Command="{Binding OptimizeDatabaseCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Eski Logları Temizle" Command="{Binding ClearOldLogsCommand}" Style="{StaticResource DangerButtonStyle}" />
                                <Button Content="Ayarları Dışa Aktar" Command="{Binding ExportSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Ayarları İçe Aktar" Command="{Binding ImportSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,12,0,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </Grid>
</Window>

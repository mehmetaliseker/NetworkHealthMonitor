                            <DataGridTextColumn Header="Bildirim turu" Binding="{Binding EventType}" Width="130" />
                            <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="1.2*" />
                            <DataGridTextColumn Header="Incident" Binding="{Binding IncidentText}" Width="85" />
                            <DataGridTextColumn Header="Olusturulma" Binding="{Binding CreatedAtText}" Width="145" />
                            <DataGridTextColumn Header="Gonderilme" Binding="{Binding SentAtText}" Width="145" />
                            <DataGridTextColumn Header="Deneme" Binding="{Binding AttemptCount}" Width="75" />
                            <DataGridTextColumn Header="Son deneme" Binding="{Binding LastAttemptAtText}" Width="145" />
                            <DataGridTextColumn Header="Sonraki deneme" Binding="{Binding NextAttemptAtText}" Width="145" />
                            <DataGridTextColumn Header="Son hata" Binding="{Binding LastError}" Width="2*" />
                            <DataGridTemplateColumn Header="Islem" Width="210">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Tekrar" Style="{StaticResource SmallButtonStyle}" Command="{Binding DataContext.RetryOutboxCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                            <Button Content="Iptal" Style="{StaticResource SmallDangerButtonStyle}" Command="{Binding DataContext.CancelPendingOutboxCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                            <Button Content="Detay" Style="{StaticResource SmallSecondaryButtonStyle}" Command="{Binding DataContext.ShowOutboxDetailCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <ScrollViewer Visibility="{Binding IsSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Style="{StaticResource SectionBorderStyle}" MaxWidth="760" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Ping Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />
                            <TextBlock Text="Varsayılan ping timeout (ms)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding PingTimeoutMs, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Cihaza, gruba, tipe veya plana özel timeout yoksa kullanılır."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Varsayılan maksimum paralel ping sayısı" FontWeight="SemiBold" />
                            <TextBox Text="{Binding MaxParallelPings, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Toplu ve otomatik pinglerde aynı anda çalışacak en fazla ping sayısı."
                                     Margin="0,4,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Otomatik Kontrol Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="Global otomatik kontrol aralığı (dk)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding AutoCheckIntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Cihaz özel aralığı 0 ve grup varsayılanı boşsa kullanılır."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Worker servis kontrol sıklığı (sn)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding SchedulerPollIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Planların zamanı gelmiş mi kontrol eden düşük maliyetli döngü sıklığı."
                                     Margin="0,4,0,12" />
                            <CheckBox Content="Global otomatik kontrol aktif"
                                      IsChecked="{Binding AutoCheckEnabled}"
                                      FontWeight="SemiBold"
                                      Margin="0,2,0,12" />
                            <TextBlock Text="Aktif planlar Windows Service tarafından çalıştırılır; arayüz kapansa da servis çalışmaya devam eder."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                            <CheckBox Content="Windows'a giris yaptigimda yonetim ekranini ac"
                                      IsChecked="{Binding OpenUiOnWindowsLogin}"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,4" />
                            <TextBlock Text="Bu secenek yalnizca WPF yonetim ekranini acar; Worker Windows Service olarak UI acilmadan calismaya devam eder."
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Retry / Akıllı Kontrol Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="Varsayılan başarısızlık eşiği" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DefaultFailureThreshold, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Bu eşikten sonra cihaz takipte/şüpheli durumuna yaklaşır; tek hata kesin arıza sayılmaz."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Varsayılan hızlı retry aralığı (sn)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DefaultFailureRetryIntervalSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Başarısız ping sonrası yalnız ilgili cihaz için uygulanacak kısa tekrar aralığı."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Varsayılan hızlı retry limiti" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DefaultFailureRetryLimit, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Hızlı retry denemeleri bu limitten sonra normal politika akışına döner."
                                     Margin="0,4,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Bildirimler" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <CheckBox Content="ntfy bildirimleri aktif" IsChecked="{Binding NotificationEnabled}" FontWeight="SemiBold" Margin="0,2,0,12" />
                            <TextBlock Text="Sunucu URL'si" FontWeight="SemiBold" />
                            <TextBox Text="{Binding NotificationBaseUrl, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Konu" FontWeight="SemiBold" />
                            <TextBox Text="{Binding NotificationTopic, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Access token" FontWeight="SemiBold" />
                            <PasswordBox infra:PasswordBoxAssistant.BoundPassword="{Binding NotificationAccessToken, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <WrapPanel Margin="0,0,0,12">
                                <CheckBox Content="Kesinti" IsChecked="{Binding NotificationNotifyOnDown}" Margin="0,0,14,0" />
                                <CheckBox Content="Duzelme" IsChecked="{Binding NotificationNotifyOnRecovered}" Margin="0,0,14,0" />
                                <CheckBox Content="IP dahil" IsChecked="{Binding NotificationIncludeIpAddress}" />
                            </WrapPanel>
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Basarisizlik esigi" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding NotificationDownFailureThreshold, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8">
                                    <TextBlock Text="Duzelme esigi" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding NotificationRecoverySuccessThreshold, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Cooldown (dk)" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding NotificationCooldownMinutes, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8">
                                    <TextBlock Text="HTTP timeout (sn)" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding NotificationRequestTimeoutSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="0,0,8,8">
                                    <TextBlock Text="Maks retry" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding NotificationMaxRetryCount, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                                <StackPanel Margin="8,0,0,8">
                                    <TextBlock Text="Ilk retry gecikmesi (sn)" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding NotificationInitialRetryDelaySeconds, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </UniformGrid>
                            <Button Content="Test bildirimi gönder" Command="{Binding SendTestNotificationCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,10" />
                            <TextBlock Text="{Binding NotificationLastTestResult}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding NotificationLastSuccessfulAtText, StringFormat=Son başarılı: {0}}" Foreground="{StaticResource MutedTextBrush}" />
                            <TextBlock Text="{Binding NotificationLastError, StringFormat=Son hata: {0}}" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Worker Sagligi" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <UniformGrid Columns="2" Margin="0,0,0,12">
                                <TextBlock Text="{Binding WorkerHealthText, StringFormat=Durum: {0}}" />
                                <TextBlock Text="{Binding WorkerVersionText, StringFormat=Surum: {0}}" />
                                <TextBlock Text="{Binding WorkerStartedAtText, StringFormat=Baslangic: {0}}" />
                                <TextBlock Text="{Binding WorkerLastSeenAtText, StringFormat=Heartbeat: {0}}" />
                                <TextBlock Text="{Binding WorkerLastSchedulerCycleText, StringFormat=Son scheduler: {0}}" />
                                <TextBlock Text="{Binding WorkerLastScheduledPingText, StringFormat=Son ping: {0}}" />
                                <TextBlock Text="{Binding WorkerLastNotificationText, StringFormat=Son bildirim: {0}}" />
                                <TextBlock Text="{Binding PendingNotificationCount, StringFormat=Bekleyen bildirim: {0}}" />
                                <TextBlock Text="{Binding FailedNotificationCount, StringFormat=Basarisiz bildirim: {0}}" />
                            </UniformGrid>
                            <Button Content="Log klasörünü aç" Command="{Binding OpenLogFolderCommand}" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Tip Bazlı Politikalar" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                            <DataGrid ItemsSource="{Binding DeviceTypePolicies}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      Height="190"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      ToolTip="Boş hücre = global varsayılan. Pozitif değer girilirse cihaz tipi varsayılanı olur.">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Tip" Binding="{Binding DeviceTypeText}" IsReadOnly="True" Width="120" />
                                    <DataGridCheckBoxColumn Header="Oto" Binding="{Binding AutoCheckEnabled}" IsThreeState="True" Width="65" />
                                    <DataGridTextColumn Header="Aralık" Binding="{Binding DefaultCheckIntervalSeconds, TargetNullValue=''}" Width="80" />
                                    <DataGridTextColumn Header="Timeout" Binding="{Binding DefaultPingTimeoutMs, TargetNullValue=''}" Width="80" />
                                    <DataGridTextColumn Header="Retry" Binding="{Binding DefaultFailureRetryIntervalSeconds, TargetNullValue=''}" Width="80" />
                                    <DataGridTextColumn Header="Limit" Binding="{Binding DefaultFailureRetryLimit, TargetNullValue=''}" Width="70" />
                                    <DataGridTextColumn Header="Eşik" Binding="{Binding DefaultFailureThreshold, TargetNullValue=''}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Log ve Availability Ayarlari" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="Log saklama süresi (gün, 0 = süresiz)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding LogRetentionDays, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Eski ping logları manuel temizlikte bu süreye göre silinir."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Heartbeat toleransi (saniye)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding HeartbeatGraceSeconds, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Worker heartbeat bu sureyi asarsa izleme boslugu Unknown kabul edilir."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Beklenen kontrol boslugu katsayisi" FontWeight="SemiBold" />
                            <TextBox Text="{Binding ExpectedCheckGraceMultiplier, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Kontrol araliginin bu kati asilirsa cihaz Unknown kabul edilebilir."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="Downtime baslangic politikasi" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding DowntimeStartPolicyOptions}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Value"
                                      SelectedValue="{Binding DowntimeStartPolicy}"
                                      Margin="0,4,0,12" />
                            <TextBlock Text="Availability period saklama (gun, 0 = suresiz)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding AvailabilityPeriodRetentionDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Incident saklama (gun, 0 = suresiz)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding IncidentRetentionDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Daily aggregate saklama (gun, 0 = suresiz)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DailyAggregateRetentionDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Dışa Aktarma Ayarları" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="CSV export klasörü" FontWeight="SemiBold" />
                            <TextBox Text="{Binding ExportDirectory, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Boş bırakılırsa dosya kaydetme penceresi son kullanılan Windows konumunu açar."
                                     Margin="0,4,0,12" />
                            <TextBlock Text="CSV ayırıcı" FontWeight="SemiBold" />
                            <TextBox Text="{Binding CsvDelimiter, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Türkiye Excel uyumu için varsayılan noktalı virgüldür."
                                     Margin="0,4,0,12" />

                            <Separator Margin="0,8,0,14" />
                            <TextBlock Text="Görünüm" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <TextBlock Text="Tema" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Theme}" Margin="0,4,0,12" />
                            <TextBlock Text="Veritabanı konumu" FontWeight="SemiBold" />
                            <Border BorderBrush="{StaticResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    Padding="9,6"
                                    Margin="0,4,0,16">
                                <TextBlock Text="{Binding DatabaseLocation, Mode=OneWay}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding DatabaseLocation, Mode=OneWay}" />
                            </Border>
                            <WrapPanel>
                                <Button Content="Ayarları Kaydet" Command="{Binding SaveSettingsCommand}" />
                                <Button Content="Ayarları Sıfırla" Command="{Binding ResetSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                            <Separator Margin="0,18,0,14" />
                            <TextBlock Text="Bakım" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                            <WrapPanel>
                                <Button Content="Veritabanını Yedekle" Command="{Binding BackupDatabaseCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Veritabanını Geri Yükle" Command="{Binding RestoreDatabaseCommand}" Style="{StaticResource DangerButtonStyle}" />
                                <Button Content="Veritabanını Optimize Et" Command="{Binding OptimizeDatabaseCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Eski Logları Temizle" Command="{Binding ClearOldLogsCommand}" Style="{StaticResource DangerButtonStyle}" />
                                <Button Content="Ayarları Dışa Aktar" Command="{Binding ExportSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Ayarları İçe Aktar" Command="{Binding ImportSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,12,0,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </Grid>
</Window>

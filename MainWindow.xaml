<Window x:Class="NetworkHealthMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:converters="clr-namespace:NetworkHealthMonitor.Converters"
        mc:Ignorable="d"
        Title="Ağ Cihazları Kontrol Paneli"
        Height="860"
        Width="1380"
        MinHeight="720"
        MinWidth="1080"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackgroundBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:StatusBackgroundConverter x:Key="StatusBackgroundConverter" />
        <converters:StatusForegroundConverter x:Key="StatusForegroundConverter" />
        <converters:RowStatusBackgroundConverter x:Key="RowStatusBackgroundConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="244" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}" Padding="18">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="Ağ Cihazları"
                               Foreground="White"
                               FontSize="21"
                               FontWeight="Bold" />
                    <TextBlock Text="Kontrol Paneli"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               Margin="0,3,0,22" />

                    <Button Content="Dashboard" Command="{Binding NavigateDashboardCommand}" Style="{StaticResource SidebarButtonStyle}" />
                    <Button Content="Cihazlar" Command="{Binding NavigateDevicesCommand}" Style="{StaticResource SidebarButtonStyle}" />
                    <Button Content="Cihaz Ekle / Düzenle" Command="{Binding NavigateDeviceEditCommand}" Style="{StaticResource SidebarButtonStyle}" />
                    <Button Content="Cihaz Grupları" Command="{Binding NavigateGroupsCommand}" Style="{StaticResource SidebarButtonStyle}" />
                    <Button Content="Otomatik Kontrol Planları" Command="{Binding NavigateSchedulesCommand}" Style="{StaticResource SidebarButtonStyle}" />
                    <Button Content="Uptime / Erişilebilirlik" Command="{Binding NavigateAvailabilityCommand}" Style="{StaticResource SidebarButtonStyle}" />
                    <Button Content="Ping Logları" Command="{Binding NavigateLogsCommand}" Style="{StaticResource SidebarButtonStyle}" />
                    <Button Content="Ayarlar" Command="{Binding NavigateSettingsCommand}" Style="{StaticResource SidebarButtonStyle}" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom" VerticalAlignment="Bottom">
                    <TextBlock Text="Scheduler"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               FontSize="12" />
                    <TextBlock Text="{Binding SchedulerStatusText}"
                               Foreground="White"
                               FontWeight="SemiBold"
                               Margin="0,2,0,10" />
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource SidebarMutedBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{Binding SectionTitle}" FontSize="24" FontWeight="Bold" />
                        <TextBlock Text="{Binding SectionSubtitle}" Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                    <WrapPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                        <Button Content="Tümüne Ping" Command="{Binding PingAllCommand}" />
                        <Button Content="Filtreye Ping" Command="{Binding PingFilteredDevicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="İptal" Command="{Binding CancelPingCommand}" Style="{StaticResource DangerButtonStyle}" />
                    </WrapPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,12,0,12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <ItemsControl Grid.Row="0" ItemsSource="{Binding SummaryCards}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Columns="4" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorderStyle}" Margin="0,0,10,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{Binding AccentColor}" CornerRadius="4" />
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Value}" FontSize="21" FontWeight="Bold" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Grid.Row="1"
                        Style="{StaticResource SectionBorderStyle}"
                        Visibility="{Binding CanShowPingProgress, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar Height="10" Minimum="0" Maximum="100" Value="{Binding PingProgressPercent}" />
                        <TextBlock Grid.Column="1" Text="{Binding StatusMessage}" Margin="12,0,0,0" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="2">
                <Grid Visibility="{Binding IsDashboardSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="360" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,12,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Son Başarısız Cihazlar" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <DataGrid ItemsSource="{Binding RecentFailureLogs}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Saat" Binding="{Binding CheckedAtText}" Width="135" />
                                    <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="*" />
                                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource SectionBorderStyle}" Margin="0,0,12,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Kritik Cihaz Durumu" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <DataGrid ItemsSource="{Binding CriticalProblemDevices}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Cihaz" Binding="{Binding Name}" Width="*" />
                                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                                    <DataGridTextColumn Header="Hata" Binding="{Binding ConsecutiveFailuresText}" Width="70" />
                                    <DataGridTextColumn Header="Son kontrol" Binding="{Binding LastCheckedAtText}" Width="145" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,12,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="Son Ping Logları" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <DataGrid ItemsSource="{Binding RecentDashboardLogs}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Saat" Binding="{Binding CheckedAtText}" Width="135" />
                                    <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="*" />
                                    <DataGridTextColumn Header="Durum" Binding="{Binding StatusText}" Width="120" />
                                    <DataGridTextColumn Header="Kaynak" Binding="{Binding TriggerTypeText}" Width="120" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SectionBorderStyle}" Margin="0,0,12,0">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="En Düşük Erişilebilirlik" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                            <DataGrid ItemsSource="{Binding LowAvailabilityDevices}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="*" />
                                    <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                                    <DataGridTextColumn Header="30 gün" Binding="{Binding Availability30DaysText}" Width="90" />
                                    <DataGridTextColumn Header="Kesinti" Binding="{Binding OutageCount}" Width="70" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.RowSpan="2" Grid.Column="2" Style="{StaticResource SectionBorderStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="Aktif Kesintiler" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <DataGrid ItemsSource="{Binding OpenOutages}" Height="190" Margin="0,0,0,14">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="*" />
                                        <DataGridTextColumn Header="Süre" Binding="{Binding DurationText}" Width="70" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="Cihaz Tipi Dağılımı" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding DeviceTypeDistribution}" Margin="0,0,0,16">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="Bold" />
                                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="8" Maximum="100" Value="{Binding Percent}" Margin="0,4,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Text="Grup Bazlı Erişilebilirlik" FontSize="16" FontWeight="Bold" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding GroupAvailabilityRows}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontWeight="Bold" />
                                                <ProgressBar Grid.Row="1" Grid.ColumnSpan="2" Height="8" Maximum="100" Value="{Binding Percent}" Margin="0,4,0,0" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding IsDevicesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBox Width="260" Text="{Binding DeviceSearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="Cihaz adı, IP, lokasyon, grup veya açıklama ara" />
                            <ComboBox Width="150" ItemsSource="{Binding DeviceTypeFilterOptions}" SelectedItem="{Binding DeviceTypeFilter}" Margin="8,0,0,0" />
                            <ComboBox Width="160" ItemsSource="{Binding DeviceStatusFilterOptions}" SelectedItem="{Binding DeviceStatusFilter}" Margin="8,0,0,0" />
                            <ComboBox Width="170" ItemsSource="{Binding DeviceGroupFilterOptions}" SelectedItem="{Binding DeviceGroupFilter}" Margin="8,0,0,0" />
                            <ComboBox Width="150" ItemsSource="{Binding CriticalFilterOptions}" SelectedItem="{Binding CriticalFilter}" Margin="8,0,0,0" />
                            <Button Content="Tipe Ping" Command="{Binding PingSelectedTypeCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="Yeni Cihaz" Command="{Binding NavigateDeviceEditCommand}" />
                            <Button Content="CSV Şablonu" Command="{Binding CreateCsvTemplateCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="CSV Import" Command="{Binding ImportDevicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="CSV Export" Command="{Binding ExportDevicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        </WrapPanel>
                    </Border>

                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding DevicesView}"
                              SelectedItem="{Binding SelectedDevice, Mode=TwoWay}">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="{Binding LastStatus, Converter={StaticResource RowStatusBackgroundConverter}}" />
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Cihaz adı" Binding="{Binding Name}" Width="1.2*" />
                            <DataGridTextColumn Header="IP adresi" Binding="{Binding IpAddress}" Width="125" SortMemberPath="IpSortKey" />
                            <DataGridTextColumn Header="Tip" Binding="{Binding DeviceTypeText}" Width="115" />
                            <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="135" />
                            <DataGridTextColumn Header="Lokasyon" Binding="{Binding Location}" Width="125" />
                            <DataGridTextColumn Header="Kritik" Binding="{Binding IsCriticalText}" Width="70" />
                            <DataGridTextColumn Header="Aktif" Binding="{Binding IsActiveText}" Width="70" />
                            <DataGridTemplateColumn Header="Durum" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding LastStatus, Converter={StaticResource StatusBackgroundConverter}}"
                                                CornerRadius="6"
                                                Padding="8,4"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding LastStatusText}"
                                                       Foreground="{Binding LastStatus, Converter={StaticResource StatusForegroundConverter}}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Gecikme" Binding="{Binding LastLatencyText}" Width="90" />
                            <DataGridTextColumn Header="24s" Binding="{Binding Uptime24HoursText}" Width="80" />
                            <DataGridTextColumn Header="Son kontrol" Binding="{Binding LastCheckedAtText}" Width="145" />
                            <DataGridTextColumn Header="Açıklama" Binding="{Binding Description}" Width="1.4*" />
                            <DataGridTemplateColumn Header="İşlemler" Width="170">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="Ping"
                                                    Style="{StaticResource SmallButtonStyle}"
                                                    Command="{Binding DataContext.PingDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Düzenle"
                                                    Style="{StaticResource SmallSecondaryButtonStyle}"
                                                    Command="{Binding DataContext.EditDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                            <Button Content="Sil"
                                                    Style="{StaticResource SmallDangerButtonStyle}"
                                                    Command="{Binding DataContext.DeleteDeviceCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                    CommandParameter="{Binding}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <ScrollViewer Visibility="{Binding IsDeviceEditSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Style="{StaticResource SectionBorderStyle}" MaxWidth="760" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="{Binding DeviceFormTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,10,12">
                                    <TextBlock Text="Cihaz adı" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding FormName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="10,0,0,12">
                                    <TextBlock Text="IP adresi" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding FormIpAddress, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,10,12">
                                    <TextBlock Text="Cihaz tipi" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding DeviceTypeOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding FormDeviceType}"
                                              Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="10,0,0,12">
                                    <TextBlock Text="Grup seçimi" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding DeviceGroupOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding FormGroupId}"
                                              Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,12">
                                    <TextBlock Text="Açıklama / lokasyon" FontWeight="SemiBold" />
                                    <TextBox Text="{Binding FormLocation, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Row="2" Grid.Column="1" Margin="10,0,0,12">
                                    <TextBlock Text="Varsayılan kontrol planı" FontWeight="SemiBold" />
                                    <ComboBox ItemsSource="{Binding SchedulePlanOptions}"
                                              DisplayMemberPath="Label"
                                              SelectedValuePath="Value"
                                              SelectedValue="{Binding FormDefaultSchedulePlanId}"
                                              Margin="0,4,0,0" />
                                </StackPanel>
                                <TextBox Grid.Row="3"
                                         Grid.ColumnSpan="2"
                                         Text="{Binding FormDescription, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="90"
                                         VerticalContentAlignment="Top"
                                         Margin="0,4,0,12"
                                         ToolTip="Açıklama" />
                                <WrapPanel Grid.Row="4" Grid.ColumnSpan="2">
                                    <CheckBox Content="Otomatik kontrol aktif" IsChecked="{Binding FormAutoCheckEnabled}" Margin="4,4,18,4" />
                                    <CheckBox Content="Kritik cihaz" IsChecked="{Binding FormIsCritical}" Margin="4,4,18,4" />
                                    <CheckBox Content="Aktif cihaz" IsChecked="{Binding FormIsActive}" Margin="4,4,18,4" />
                                </WrapPanel>
                            </Grid>
                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="{Binding DeviceFormActionText}" Command="{Binding SaveDeviceCommand}" />
                                <Button Content="Temizle" Command="{Binding ClearDeviceFormCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Cihaz Listesine Dön" Command="{Binding NavigateDevicesCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>

                <Grid Visibility="{Binding IsGroupsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="380" />
                    </Grid.ColumnDefinitions>
                    <DataGrid ItemsSource="{Binding DeviceGroups}"
                              SelectedItem="{Binding SelectedGroup}"
                              Margin="0,0,12,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Grup adı" Binding="{Binding Name}" Width="1.2*" />
                            <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceCountText}" Width="80" />
                            <DataGridTextColumn Header="30 gün erişilebilirlik" Binding="{Binding Availability30DaysText}" Width="145" />
                            <DataGridTextColumn Header="Açıklama" Binding="{Binding Description}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Column="1" Style="{StaticResource SectionBorderStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding GroupFormTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                                <TextBlock Text="Grup adı" FontWeight="SemiBold" />
                                <TextBox Text="{Binding GroupFormName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                                <TextBlock Text="Gruba özel varsayılan plan" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding SchedulePlanOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding GroupFormDefaultSchedulePlanId}"
                                          Margin="0,4,0,12" />
                                <TextBlock Text="Açıklama" FontWeight="SemiBold" />
                                <TextBox Text="{Binding GroupFormDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Height="90"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Top"
                                         Margin="0,4,0,14" />
                                <WrapPanel>
                                    <Button Content="{Binding GroupFormActionText}" Command="{Binding SaveGroupCommand}" />
                                    <Button Content="Temizle" Command="{Binding ClearGroupFormCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                                <Separator Margin="0,16,0,14" />
                                <TextBlock Text="Seçili Grup" FontSize="16" FontWeight="Bold" Margin="0,0,0,10" />
                                <TextBlock Text="{Binding SelectedGroup.Name, TargetNullValue=-}" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SelectedGroup.Description, TargetNullValue=-}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,12" />
                                <WrapPanel>
                                    <Button Content="Ping" Command="{Binding PingSelectedGroupCommand}" Style="{StaticResource SmallButtonStyle}" />
                                    <Button Content="Düzenle" Command="{Binding EditSelectedGroupCommand}" Style="{StaticResource SmallSecondaryButtonStyle}" />
                                    <Button Content="Sil" Command="{Binding DeleteSelectedGroupCommand}" Style="{StaticResource SmallDangerButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding IsSchedulesSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="420" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="Scheduler:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="4,0,4,0" />
                            <TextBlock Text="{Binding SchedulerStatusText}" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,14,0" />
                            <Button Content="Başlat" Command="{Binding StartSchedulerCommand}" />
                            <Button Content="Durdur" Command="{Binding StopSchedulerCommand}" Style="{StaticResource DangerButtonStyle}" />
                            <Button Content="Seçili Planı Çalıştır" Command="{Binding RunSelectedSchedulePlanCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        </WrapPanel>
                    </Border>
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding SchedulePlans}"
                              SelectedItem="{Binding SelectedSchedulePlan}"
                              Margin="0,0,12,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Plan adı" Binding="{Binding Name}" Width="1.2*" />
                            <DataGridTextColumn Header="Tip" Binding="{Binding TargetTypeText}" Width="135" />
                            <DataGridTextColumn Header="Hedef" Binding="{Binding TargetDisplayName}" Width="1.2*" />
                            <DataGridTextColumn Header="Sıklık" Binding="{Binding IntervalText}" Width="80" />
                            <DataGridTextColumn Header="Timeout" Binding="{Binding TimeoutMs}" Width="80" />
                            <DataGridTextColumn Header="Paralel" Binding="{Binding MaxParallelism}" Width="75" />
                            <DataGridTextColumn Header="Eşik" Binding="{Binding FailureThreshold}" Width="60" />
                            <DataGridTextColumn Header="Durum" Binding="{Binding IsActiveText}" Width="80" />
                            <DataGridTextColumn Header="Son çalışma" Binding="{Binding LastRunAtText}" Width="145" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource SectionBorderStyle}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding PlanFormTitle}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                                <TextBlock Text="Plan adı" FontWeight="SemiBold" />
                                <TextBox Text="{Binding PlanFormName, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
                                <TextBlock Text="Plan tipi" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding PlanTargetTypeOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding PlanFormTargetType}"
                                          Margin="0,4,0,10" />
                                <TextBlock Text="Hedef seçimi" FontWeight="SemiBold" />
                                <ComboBox ItemsSource="{Binding PlanTargetOptions}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="Value"
                                          SelectedValue="{Binding PlanFormTargetValue}"
                                          Margin="0,4,0,10" />
                                <TextBlock Text="Kontrol sıklığı" FontWeight="SemiBold" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,10">
                                    <TextBox Width="90" Text="{Binding PlanFormFrequencyValue, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox Width="120" ItemsSource="{Binding FrequencyUnitOptions}" SelectedItem="{Binding PlanFormFrequencyUnit}" Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="Ping timeout (ms)" FontWeight="SemiBold" />
                                <TextBox Text="{Binding PlanFormTimeoutMs, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
                                <TextBlock Text="Maksimum paralel işlem" FontWeight="SemiBold" />
                                <TextBox Text="{Binding PlanFormMaxParallelism, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
                                <TextBlock Text="Başarısızlık eşiği" FontWeight="SemiBold" />
                                <TextBox Text="{Binding PlanFormFailureThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
                                <CheckBox Content="Plan aktif" IsChecked="{Binding PlanFormIsActive}" FontWeight="SemiBold" Margin="0,2,0,10" />
                                <TextBlock Text="Açıklama" FontWeight="SemiBold" />
                                <TextBox Text="{Binding PlanFormDescription, UpdateSourceTrigger=PropertyChanged}"
                                         Height="78"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         VerticalContentAlignment="Top"
                                         Margin="0,4,0,14" />
                                <WrapPanel>
                                    <Button Content="{Binding PlanFormActionText}" Command="{Binding SaveSchedulePlanCommand}" />
                                    <Button Content="Temizle" Command="{Binding ClearSchedulePlanFormCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                </WrapPanel>
                                <Separator Margin="0,16,0,14" />
                                <WrapPanel>
                                    <Button Content="Düzenle" Command="{Binding EditSelectedSchedulePlanCommand}" Style="{StaticResource SmallSecondaryButtonStyle}" />
                                    <Button Content="Sil" Command="{Binding DeleteSelectedSchedulePlanCommand}" Style="{StaticResource SmallDangerButtonStyle}" />
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <Grid Visibility="{Binding IsAvailabilitySection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding AvailabilityNotice}" TextWrapping="Wrap" Foreground="{StaticResource MutedTextBrush}" />
                            <WrapPanel Grid.Column="1">
                                <Button Content="Yenile" Command="{Binding RefreshAvailabilityCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="CSV Export" Command="{Binding ExportAvailabilityCommand}" />
                            </WrapPanel>
                        </Grid>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding AvailabilityItems}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="1.1*" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                            <DataGridTextColumn Header="Tip" Binding="{Binding DeviceTypeText}" Width="110" />
                            <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="130" />
                            <DataGridTextColumn Header="Son durum" Binding="{Binding LastStatusText}" Width="115" />
                            <DataGridTextColumn Header="Son başarılı" Binding="{Binding LastSuccessfulCheckAtText}" Width="145" />
                            <DataGridTextColumn Header="Son başarısız" Binding="{Binding LastFailedCheckAtText}" Width="145" />
                            <DataGridTextColumn Header="Başarılı" Binding="{Binding TotalSuccessCount}" Width="75" />
                            <DataGridTextColumn Header="Başarısız" Binding="{Binding TotalFailureCount}" Width="80" />
                            <DataGridTextColumn Header="Ölçülen" Binding="{Binding MeasuredAvailabilityText}" Width="90" />
                            <DataGridTextColumn Header="24 saat" Binding="{Binding Availability24HoursText}" Width="85" />
                            <DataGridTextColumn Header="7 gün" Binding="{Binding Availability7DaysText}" Width="85" />
                            <DataGridTextColumn Header="30 gün" Binding="{Binding Availability30DaysText}" Width="85" />
                            <DataGridTextColumn Header="Kesinti" Binding="{Binding OutageCount}" Width="70" />
                            <DataGridTextColumn Header="Son kesinti" Binding="{Binding LastOutageStartedAtText}" Width="145" />
                            <DataGridTextColumn Header="Toparlanma" Binding="{Binding LastRecoveryAtText}" Width="145" />
                            <DataGridTextColumn Header="Kesinti süresi" Binding="{Binding EstimatedOutageDurationText}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <Grid Visibility="{Binding IsLogsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Style="{StaticResource SectionBorderStyle}" Margin="0,0,0,12">
                        <WrapPanel VerticalAlignment="Center">
                            <DatePicker Width="140" SelectedDate="{Binding LogStartDate}" />
                            <DatePicker Width="140" SelectedDate="{Binding LogEndDate}" Margin="8,0,0,0" />
                            <TextBox Width="170" Text="{Binding LogDeviceNameFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="Cihaz adı" Margin="8,0,0,0" />
                            <TextBox Width="135" Text="{Binding LogIpAddressFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="IP adresi" Margin="8,0,0,0" />
                            <ComboBox Width="135" ItemsSource="{Binding DeviceTypeFilterOptions}" SelectedItem="{Binding LogDeviceTypeFilter}" Margin="8,0,0,0" />
                            <ComboBox Width="145" ItemsSource="{Binding DeviceStatusFilterOptions}" SelectedItem="{Binding LogStatusFilter}" Margin="8,0,0,0" />
                            <ComboBox Width="145" ItemsSource="{Binding DeviceGroupFilterOptions}" SelectedItem="{Binding LogGroupFilter}" Margin="8,0,0,0" />
                            <ComboBox Width="145" ItemsSource="{Binding TriggerFilterOptions}" SelectedItem="{Binding LogTriggerFilter}" Margin="8,0,0,0" />
                            <TextBox Width="150" Text="{Binding LogPlanNameFilter, UpdateSourceTrigger=PropertyChanged}" ToolTip="Plan adı" Margin="8,0,0,0" />
                            <CheckBox Content="Sadece erişilemeyen" IsChecked="{Binding LogOnlyUnreachable}" VerticalAlignment="Center" Margin="10,0,0,0" />
                            <Button Content="Filtrele" Command="{Binding RefreshLogsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            <Button Content="CSV Export" Command="{Binding ExportLogsCommand}" />
                            <Button Content="Eski Logları Temizle" Command="{Binding ClearOldLogsCommand}" Style="{StaticResource DangerButtonStyle}" />
                            <Button Content="Tüm Logları Temizle" Command="{Binding ClearLogsCommand}" Style="{StaticResource DangerButtonStyle}" />
                        </WrapPanel>
                    </Border>
                    <DataGrid Grid.Row="1" ItemsSource="{Binding LogsView}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tarih/Saat" Binding="{Binding CheckedAtText}" Width="150" />
                            <DataGridTextColumn Header="Cihaz" Binding="{Binding DeviceName}" Width="1.1*" />
                            <DataGridTextColumn Header="IP" Binding="{Binding IpAddress}" Width="120" />
                            <DataGridTextColumn Header="Tip" Binding="{Binding DeviceTypeText}" Width="110" />
                            <DataGridTextColumn Header="Grup" Binding="{Binding GroupName}" Width="120" />
                            <DataGridTemplateColumn Header="Durum" Width="130">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Status, Converter={StaticResource StatusBackgroundConverter}}"
                                                CornerRadius="6"
                                                Padding="8,4"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding StatusText}"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusForegroundConverter}}"
                                                       FontWeight="SemiBold" />
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Gecikme" Binding="{Binding LatencyText}" Width="85" />
                            <DataGridTextColumn Header="Kaynak" Binding="{Binding TriggerTypeText}" Width="130" />
                            <DataGridTextColumn Header="Plan" Binding="{Binding SchedulePlanName}" Width="150" />
                            <DataGridTextColumn Header="Mesaj" Binding="{Binding ResponseOrErrorText}" Width="2*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <ScrollViewer Visibility="{Binding IsSettingsSection, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Border Style="{StaticResource SectionBorderStyle}" MaxWidth="680" HorizontalAlignment="Left">
                        <StackPanel>
                            <TextBlock Text="Genel Ayarlar" FontSize="18" FontWeight="Bold" Margin="0,0,0,14" />
                            <TextBlock Text="Varsayılan ping timeout (ms)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding PingTimeoutMs, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Varsayılan maksimum paralel ping sayısı" FontWeight="SemiBold" />
                            <TextBox Text="{Binding MaxParallelPings, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Varsayılan başarısızlık eşiği" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DefaultFailureThreshold, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Log saklama süresi (gün, 0 = süresiz)" FontWeight="SemiBold" />
                            <TextBox Text="{Binding LogRetentionDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Tema" FontWeight="SemiBold" />
                            <ComboBox ItemsSource="{Binding ThemeOptions}" SelectedItem="{Binding Theme}" Margin="0,4,0,12" />
                            <CheckBox Content="Uygulama başlangıcında otomatik planları başlat"
                                      IsChecked="{Binding StartSchedulePlansOnStartup}"
                                      FontWeight="SemiBold"
                                      Margin="0,2,0,12" />
                            <TextBlock Text="CSV ayırıcı" FontWeight="SemiBold" />
                            <TextBox Text="{Binding CsvDelimiter, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                            <TextBlock Text="Veritabanı konumu" FontWeight="SemiBold" />
                            <TextBox Text="{Binding DatabaseLocation}" IsReadOnly="True" Margin="0,4,0,16" />
                            <WrapPanel>
                                <Button Content="Ayarları Kaydet" Command="{Binding SaveSettingsCommand}" />
                                <Button Content="Ayarları Sıfırla" Command="{Binding ResetSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                            <Separator Margin="0,18,0,14" />
                            <TextBlock Text="Bakım" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                            <WrapPanel>
                                <Button Content="Veritabanını Yedekle" Command="{Binding BackupDatabaseCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Veritabanını Geri Yükle" Command="{Binding RestoreDatabaseCommand}" Style="{StaticResource DangerButtonStyle}" />
                                <Button Content="Ayarları Dışa Aktar" Command="{Binding ExportSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                                <Button Content="Ayarları İçe Aktar" Command="{Binding ImportSettingsCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </Grid>

            <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,12,0,0">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedTextBrush}" TextTrimming="CharacterEllipsis" />
            </Border>
        </Grid>
    </Grid>
</Window>
